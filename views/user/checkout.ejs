                                <p style="text-align:center;color:#666;padding:20px;">No saved addresses. Please add a new address.</p>
                            <% } %>
                        </div>

                        <!-- New Address -->
                        <div class="new-address-container <%= addresses.length === 0 ? 'show' : '' %>" id="new-address">
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="addressType">Address Type</label>
                                    <select id="addressType" name="addressType">
                                        <option value="Home">Home</option>
                                        <option value="Work">Work</option>
                                        <option value="Other">Other</option>
                                    </select>
