<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - Kids Fashion Store</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <%- include("../../views/partials/user/header") %>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #f7f4ef 0%, #e8ddd4 100%);
            min-height: 100vh;
            padding: 20px 0;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

        /* ── Header ── */
        .checkout-header {
            background: white; border-radius: 20px; padding: 30px 40px;
            margin-bottom: 30px; box-shadow: 0 8px 30px rgba(0,0,0,.1);
            position: relative; overflow: hidden;
        }
        .checkout-header::before {
            content:''; position:absolute; top:0; left:0; right:0; height:5px;
            background: linear-gradient(90deg,#D4B896,#C8A882);
        }
        .checkout-title { display:flex; align-items:center; gap:15px; margin-bottom:10px; }
        .checkout-title h1 { font-size:2.5rem; color:#333; font-weight:700; }
        .checkout-title i  { font-size:2rem; color:#D4B896; }
        .checkout-subtitle { color:#666; font-size:1.1rem; }
        .breadcrumb { display:flex; align-items:center; gap:10px; margin-top:15px; font-size:.9rem; }
        .breadcrumb a { color:#D4B896; text-decoration:none; font-weight:600; }
        .breadcrumb a:hover { color:#C8A882; }
        .breadcrumb span { color:#999; }

        /* ── Progress ── */
        .progress-steps {
            display:flex; justify-content:center; align-items:center;
            margin-bottom:40px; padding:20px;
            background:white; border-radius:15px; box-shadow:0 4px 15px rgba(0,0,0,.05);
        }
        .step { display:flex; align-items:center; color:#999; }
        .step.active  { color:#D4B896; }
        .step.completed { color:#27ae60; }
        .step-number {
            width:35px; height:35px; border-radius:50%; background:#f0f0f0;
            display:flex; align-items:center; justify-content:center;
            font-weight:600; margin-right:10px;
        }
        .step.active .step-number   { background:#D4B896; color:white; }
        .step.completed .step-number{ background:#27ae60;  color:white; }
        .step-connector { width:80px; height:2px; background:#e0e0e0; margin:0 20px; }

        /* ── Layout ── */
        .checkout-layout { display:grid; grid-template-columns:1fr 400px; gap:30px; }

        /* ── Form card ── */
        .checkout-form {
            background:white; border-radius:20px; padding:40px;
            box-shadow:0 8px 30px rgba(0,0,0,.1);
        }
        .form-section { margin-bottom:30px; padding-bottom:30px; border-bottom:2px solid #f0f0f0; }
        .form-section:last-child { border-bottom:none; margin-bottom:0; padding-bottom:0; }
        .section-title { font-size:1.3rem; color:#333; margin-bottom:20px; display:flex; align-items:center; gap:10px; }
        .section-title i { color:#D4B896; }

        .form-row { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:20px; }
        .form-group { margin-bottom:20px; }
        .form-group label { display:block; font-size:14px; font-weight:600; margin-bottom:8px; color:#333; }
        .form-group input,
        .form-group select,
        .form-group textarea {
            width:100%; padding:12px 15px; border:2px solid #e0e0e0; border-radius:10px;
            font-size:14px; transition:all .3s; background:#fafafa;
        }
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline:none; border-color:#D4B896; background:white;
            box-shadow:0 0 0 3px rgba(212,184,150,.1);
        }
        .error-message { color:#e74c3c; font-size:12px; margin-top:5px; display:none; }

        /* ── Address UI ── */
        .address-selection { background:#f8f9fa; border-radius:15px; padding:25px; margin-bottom:25px; border:2px solid #e9ecef; }
        .address-options   { display:flex; gap:15px; margin-bottom:20px; }
        .address-toggle-btn {
            padding:10px 20px; border:2px solid #e0e0e0; border-radius:8px;
            background:white; color:#666; cursor:pointer; font-weight:600;
            transition:all .3s; flex:1; text-align:center;
        }
        .address-toggle-btn.active        { border-color:#D4B896; background:#D4B896; color:white; }
        .address-toggle-btn:hover:not(.active) { border-color:#D4B896; color:#D4B896; }

        .saved-addresses-container { display:none; }
        .saved-addresses-container.show { display:block; }
        .new-address-container { display:none; }
        .new-address-container.show { display:block; }

        .saved-address-card {
            background:white; border:2px solid #e0e0e0; border-radius:12px;
            padding:20px; margin-bottom:15px; cursor:pointer;
            transition:all .3s; position:relative;
        }
        .saved-address-card:hover   { border-color:#D4B896; box-shadow:0 4px 15px rgba(212,184,150,.1); }
        .saved-address-card.selected{ border-color:#D4B896; background:rgba(212,184,150,.05); }
        .address-radio { position:absolute; top:15px; right:15px; z-index:10; }
        .address-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
        .address-type { background:#D4B896; color:white; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:600; }
        .address-type.default { background:#27ae60; }
        .address-name    { font-weight:700; color:#333; font-size:1.1rem; }
        .address-details { color:#666; font-size:14px; line-height:1.5; margin-right:30px; }

        .address-actions { position:absolute; top:15px; right:50px; display:flex; gap:8px; opacity:0; transition:opacity .3s; z-index:5; }
        .saved-address-card:hover .address-actions { opacity:1; }
        .address-action-btn {
            width:30px; height:30px; border:none; border-radius:6px; cursor:pointer;
            display:flex; align-items:center; justify-content:center; font-size:12px;
            transition:all .3s; background:rgba(255,255,255,.9);
            backdrop-filter:blur(10px); box-shadow:0 2px 8px rgba(0,0,0,.1);
        }
        .address-action-btn.edit   { color:#D4B896; border:1px solid #D4B896; }
        .address-action-btn.edit:hover   { background:#D4B896; color:white; transform:translateY(-2px); }
        .address-action-btn.delete { color:#e74c3c; border:1px solid #e74c3c; }
        .address-action-btn.delete:hover { background:#e74c3c; color:white; transform:translateY(-2px); }

        .edit-address-actions { display:none; margin-top:20px; padding:20px; background:rgba(212,184,150,.1); border-radius:10px; border:2px solid #D4B896; }
        .edit-address-actions.show { display:block; }
        .save-address-btn {
            background:linear-gradient(135deg,#D4B896 0%,#C8A882 100%); color:white;
            border:none; padding:12px 25px; border-radius:8px; font-weight:600;
            cursor:pointer; transition:all .3s; margin-right:10px;
        }
        .save-address-btn:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(212,184,150,.4); }
        .cancel-edit-btn {
            background:#f8f9fa; color:#666; border:2px solid #e9ecef;
            padding:12px 25px; border-radius:8px; font-weight:600; cursor:pointer; transition:all .3s;
        }
        .cancel-edit-btn:hover { background:#e9ecef; color:#333; }

        /* ── Payment ── */
        .payment-methods { display:grid; grid-template-columns:1fr 1fr; gap:15px; }
        .payment-option {
            padding:20px; border:2px solid #e0e0e0; border-radius:12px;
            cursor:pointer; transition:all .3s; display:flex; align-items:center; gap:15px;
        }
        .payment-option:hover   { border-color:#D4B896; box-shadow:0 4px 15px rgba(212,184,150,.1); }
        .payment-option.selected{ border-color:#D4B896; background:rgba(212,184,150,.05); }
        .payment-option input[type="radio"] { width:auto; margin:0; }
        .payment-icon   { font-size:1.5rem; color:#D4B896; }
        .payment-details h4 { font-size:1rem; color:#333; margin-bottom:4px; }
        .payment-details p  { font-size:.85rem; color:#666; }

        .card-details { display:none; margin-top:20px; padding:20px; background:#f8f9fa; border-radius:12px; }
        .card-details.show { display:block; }
        .card-row { display:grid; grid-template-columns:2fr 1fr; gap:15px; }

        /* ══════════════════════════════════════════════════════════════════
           COUPON SECTION
        ══════════════════════════════════════════════════════════════════ */
        .coupon-section {
            background: linear-gradient(135deg, #fffdf9 0%, #fdf6ed 100%);
            border: 2px dashed #D4B896;
            border-radius: 16px;
            padding: 24px;
        }

        .coupon-input-row {
            display: flex;
            gap: 10px;
            margin-bottom: 14px;
        }

        .coupon-input-row input {
            flex: 1;
            padding: 12px 16px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: all .3s;
            background: white;
        }
        .coupon-input-row input:focus {
            outline: none;
            border-color: #D4B896;
            box-shadow: 0 0 0 3px rgba(212,184,150,.15);
        }
        .coupon-input-row input:disabled {
            background: #f0f0f0;
            cursor: not-allowed;
        }

        .apply-coupon-btn {
            padding: 12px 24px;
            background: linear-gradient(135deg, #D4B896 0%, #C8A882 100%);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: all .3s;
            white-space: nowrap;
        }
        .apply-coupon-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(212,184,150,.4); }
        .apply-coupon-btn:disabled { opacity:.6; cursor:not-allowed; transform:none; }

        /* Applied coupon badge */
        .coupon-applied-badge {
            display: none;
            align-items: center;
            gap: 10px;
            padding: 10px 16px;
            background: rgba(39,174,96,.08);
            border: 1.5px solid #27ae60;
            border-radius: 10px;
            margin-bottom: 14px;
        }
        .coupon-applied-badge.show { display: flex; }
        .coupon-applied-badge .badge-code {
            font-weight: 800;
            color: #27ae60;
            font-size: 15px;
            letter-spacing: 1px;
            flex: 1;
        }
        .coupon-applied-badge .badge-saving {
            font-size: 13px;
            color: #27ae60;
            font-weight: 600;
        }
        .remove-coupon-btn {
            background: none;
            border: 1.5px solid #e74c3c;
            color: #e74c3c;
            border-radius: 8px;
            padding: 4px 10px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all .25s;
        }
        .remove-coupon-btn:hover { background: #e74c3c; color: white; }

        /* Browse coupons link */
        .view-coupons-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #D4B896;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: underline;
            background: none;
            border: none;
            padding: 0;
        }
        .view-coupons-link:hover { color: #C8A882; }

        /* ── Coupon Modal ── */
        .coupon-modal-overlay {
            display: none;
            position: fixed; inset: 0;
            background: rgba(0,0,0,.5);
            z-index: 9000;
            align-items: center;
            justify-content: center;
        }
        .coupon-modal-overlay.show { display: flex; }

        .coupon-modal {
            background: white;
            border-radius: 20px;
            padding: 32px;
            width: 90%;
            max-width: 500px;
            max-height: 80vh;
            overflow-y: auto;
            box-shadow: 0 20px 60px rgba(0,0,0,.2);
            position: relative;
            animation: modalIn .3s ease;
        }
        @keyframes modalIn {
            from { opacity:0; transform:translateY(30px) scale(.96); }
            to   { opacity:1; transform:translateY(0)   scale(1); }
        }

        .coupon-modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 2px solid #f0f0f0;
        }
        .coupon-modal-header h3 { font-size: 1.4rem; color: #333; font-weight: 700; }
        .modal-close-btn {
            width: 36px; height: 36px; border-radius: 50%;
            border: 2px solid #e0e0e0; background: white;
            color: #666; font-size: 16px; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: all .25s;
        }
        .modal-close-btn:hover { background: #e74c3c; border-color: #e74c3c; color: white; }

        /* Coupon cards inside modal */
        .coupon-card {
            border: 2px solid #e9ecef;
            border-radius: 14px;
            padding: 18px 20px;
            margin-bottom: 14px;
            position: relative;
            overflow: hidden;
            transition: all .25s;
        }
        .coupon-card.eligible {
            border-color: #D4B896;
            background: linear-gradient(135deg, #fffdf9 0%, #fdf6ed 100%);
        }
        .coupon-card.ineligible {
            opacity: .6;
        }
        .coupon-card::before {
            content: '';
            position: absolute;
            left: 0; top: 0; bottom: 0;
            width: 6px;
            background: linear-gradient(180deg, #D4B896, #C8A882);
            border-radius: 14px 0 0 14px;
        }
        .coupon-card.ineligible::before { background: #ccc; }

        .coupon-card-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 8px;
        }
        .coupon-name {
            font-size: 1.1rem;
            font-weight: 800;
            color: #333;
            letter-spacing: 1px;
        }
        .coupon-discount-badge {
            background: linear-gradient(135deg, #D4B896, #C8A882);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 700;
        }
        .coupon-card-meta {
            font-size: 12.5px;
            color: #666;
            margin-bottom: 12px;
            line-height: 1.6;
        }
        .coupon-card-meta span { display: inline-block; margin-right: 12px; }
        .coupon-card-meta i { margin-right: 4px; color: #D4B896; }

        .use-coupon-btn {
            padding: 8px 20px;
            background: linear-gradient(135deg, #D4B896 0%, #C8A882 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 700;
            font-size: 13px;
            cursor: pointer;
            transition: all .25s;
        }
        .use-coupon-btn:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(212,184,150,.4); }

        .ineligible-notice {
            font-size: 12px;
            color: #e74c3c;
            font-weight: 600;
            padding: 6px 14px;
            background: rgba(231,76,60,.08);
            border-radius: 6px;
            border: 1px solid rgba(231,76,60,.2);
            display: inline-block;
        }

        .no-coupons { text-align:center; padding:30px; color:#999; }
        .no-coupons i { font-size:2.5rem; color:#ddd; display:block; margin-bottom:12px; }

        /* ── Order Summary ── */
        .order-summary {
            background:white; border-radius:20px; padding:30px;
            box-shadow:0 8px 30px rgba(0,0,0,.1);
            height:fit-content; position:sticky; top:20px;
        }
        .summary-items { max-height:300px; overflow-y:auto; margin-bottom:20px; }
        .summary-item  { display:flex; gap:15px; padding:15px 0; border-bottom:1px solid #f0f0f0; }
        .summary-item:last-child { border-bottom:none; }
        .item-image    { width:60px; height:60px; border-radius:8px; object-fit:cover; }
        .item-info     { flex:1; }
        .item-name     { font-size:14px; font-weight:600; color:#333; margin-bottom:4px; }
        .item-details  { font-size:12px; color:#666; margin-bottom:4px; }
        .item-price    { font-size:14px; font-weight:600; color:#D4B896; }

        .summary-row { display:flex; justify-content:space-between; margin-bottom:12px; font-size:14px; }
        .summary-row.total {
            font-size:1.2rem; font-weight:700; color:#333;
            padding-top:15px; border-top:2px solid #f0f0f0; margin-top:20px;
        }
        /* Coupon discount row inside summary */
        .summary-row.discount-row { color:#27ae60; font-weight:600; }
        .summary-row.discount-row span:last-child::before { content: '- '; }

        .place-order-btn {
            width:100%; padding:18px;
            background:linear-gradient(135deg,#D4B896 0%,#C8A882 100%);
            color:white; border:none; border-radius:12px;
            font-size:1.1rem; font-weight:700; cursor:pointer;
            transition:all .3s; margin-top:20px;
        }
        .place-order-btn:hover { transform:translateY(-2px); box-shadow:0 10px 25px rgba(212,184,150,.4); }
        .place-order-btn:disabled { opacity:.6; cursor:not-allowed; transform:none; }

        .security-badge {
            display:flex; align-items:center; justify-content:center; gap:8px;
            margin-top:15px; padding:10px;
            background:rgba(39,174,96,.1); border-radius:8px;
            color:#27ae60; font-size:12px;
        }

        /* ── Loading spinner ── */
        .loading { display:none; align-items:center; gap:10px; }
        .spinner { width:20px; height:20px; border:2px solid #f3f3f3; border-top:2px solid #D4B896; border-radius:50%; animation:spin 1s linear infinite; }
        @keyframes spin { 0%{transform:rotate(0deg)} 100%{transform:rotate(360deg)} }

        /* ── Responsive ── */
        @media (max-width:768px) {
            .checkout-layout       { grid-template-columns:1fr; gap:20px; }
            .checkout-header       { padding:25px 20px; }
            .checkout-title h1     { font-size:2rem; }
            .checkout-form, .order-summary { padding:25px 20px; }
            .form-row              { grid-template-columns:1fr; gap:15px; }
            .payment-methods       { grid-template-columns:1fr; }
            .card-row              { grid-template-columns:1fr; }
            .progress-steps        { flex-direction:column; gap:10px; }
            .step-connector        { width:2px; height:30px; margin:10px 0; }
            .address-options       { flex-direction:column; }
            .coupon-input-row      { flex-direction:column; }
        }

        @keyframes fadeIn {
            from { opacity:0; transform:translateY(20px); }
            to   { opacity:1; transform:translateY(0); }
        }
        .checkout-form, .order-summary { animation:fadeIn .5s ease-in-out; }

        /* SweetAlert custom */
        .custom-swal-popup    { border-radius:20px !important; padding:2rem !important; }
        .custom-swal-title    { color:#333 !important; font-weight:700 !important; }
        .custom-swal-confirm-btn {
            background:linear-gradient(135deg,#D4B896 0%,#C8A882 100%) !important;
            border:none !important; border-radius:10px !important;
            padding:10px 30px !important; font-weight:600 !important;
        }
        .custom-swal-cancel-btn {
            background:#f8f9fa !important; color:#666 !important;
            border:2px solid #e9ecef !important; border-radius:10px !important;
            padding:10px 30px !important; font-weight:600 !important;
        }
    </style>
</head>
<body>
<div class="container">

    <!-- Header -->
    <div class="checkout-header">
        <div class="checkout-title">
            <i class="fas fa-credit-card"></i>
            <h1>Checkout</h1>
        </div>
        <p class="checkout-subtitle">Complete your order securely</p>
        <div class="breadcrumb">
            <a href="/">Home</a><span>/</span>
            <a href="/shop">Shop</a><span>/</span>
            <a href="/cart">Cart</a><span>/</span>
            <span>Checkout</span>
        </div>
    </div>

    <!-- Progress Steps -->
    <div class="progress-steps">
        <div class="step completed"><div class="step-number">1</div><span>Cart</span></div>
        <div class="step-connector"></div>
        <div class="step active"><div class="step-number">2</div><span>Checkout</span></div>
        <div class="step-connector"></div>
        <div class="step"><div class="step-number">3</div><span>Payment</span></div>
        <div class="step-connector"></div>
        <div class="step"><div class="step-number">4</div><span>Complete</span></div>
    </div>

    <!-- Main Layout -->
    <div class="checkout-layout">

        <!-- ── Checkout Form ── -->
        <div class="checkout-form">
            <form id="checkout-form" method="POST" action="/user/checkout">

                <!-- Shipping -->
                <div class="form-section">
                    <div class="section-title"><i class="fas fa-truck"></i> Shipping Information</div>

                    <div class="address-selection">
                        <div class="address-options">
                            <button type="button" class="address-toggle-btn <%= addresses.length > 0 ? 'active' : '' %>" onclick="toggleAddressMode('saved')">
                                <i class="fas fa-map-marker-alt"></i> Use Saved Address
                            </button>
                            <button type="button" class="address-toggle-btn <%= addresses.length === 0 ? 'active' : '' %>" onclick="toggleAddressMode('new')">
                                <i class="fas fa-plus"></i> Add New Address
                            </button>
                        </div>

                        <!-- Saved Addresses -->
                        <div class="saved-addresses-container <%= addresses.length > 0 ? 'show' : '' %>" id="saved-addresses">
                            <% if (addresses && addresses.length > 0) { %>
                                <% addresses.forEach((address, index) => { %>
                                    <div class="saved-address-card <%= address.isDefault || index === 0 ? 'selected' : '' %>" onclick="selectAddress('<%= address._id %>')">
                                        <input type="radio" name="selectedAddress" value="<%= address._id %>" class="address-radio" <%= address.isDefault || index === 0 ? 'checked' : '' %>>

                                        <div class="address-actions">
                                            <button type="button" class="address-action-btn edit" onclick="editAddress(event,'<%= address._id %>')" title="Edit"><i class="fas fa-edit"></i></button>
                                            <button type="button" class="address-action-btn delete" onclick="deleteAddress(event,'<%= address._id %>')" title="Delete"><i class="fas fa-trash"></i></button>
                                        </div>

                                        <div class="address-header">
                                            <div class="address-name"><%= address.name %></div>
                                            <div class="address-type <%= address.isDefault ? 'default' : '' %>">
                                                <%= address.isDefault ? 'Default' : address.addressType %>
                                            </div>
                                        </div>
                                        <div class="address-details">
                                            <%= address.address %><br>
                                            <%= address.city %>, <%= address.state %> <%= address.zipCode %><br>
                                            <%= address.country %><br>
                                            Phone: <%= address.phone %>
                                        </div>
                                    </div>
                                <% }); %>
