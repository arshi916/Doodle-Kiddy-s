<script>

const countryStateData = <%- countryStateData %>;
let currentEditId  = null;
let appliedCouponCode = '';   // tracks what's currently applied

function toggleAddressMode(mode) {
    const saved   = document.getElementById('saved-addresses');
    const newAddr = document.getElementById('new-address');
    const btns    = document.querySelectorAll('.address-toggle-btn');
    btns.forEach(b => b.classList.remove('active'));
    if (mode === 'saved') {
        saved.classList.add('show');
        newAddr.classList.remove('show');
        btns[0].classList.add('active');
    } else {
        saved.classList.remove('show');
        newAddr.classList.add('show');
        btns[1].classList.add('active');
        loadStates();
    }
}

function selectAddress(addressId) {
    document.querySelectorAll('.saved-address-card').forEach(c => c.classList.remove('selected'));
    event.currentTarget.classList.add('selected');
    document.querySelectorAll('input[name="selectedAddress"]').forEach(r => { r.checked = r.value === addressId; });
}

async function editAddress(event, addressId) {
    event.stopPropagation();
    currentEditId = addressId;
    try {
        const res  = await fetch(`/user/checkout/address/${addressId}`);
        const data = await res.json();
        if (data.success) {
            const a = data.address;
            toggleAddressMode('new');
            document.getElementById('addressType').value = a.addressType;
            document.getElementById('firstName').value   = a.name;
            document.getElementById('phone').value       = a.phone;
            document.getElementById('address').value     = a.address;
            document.getElementById('city').value        = a.city;
            document.getElementById('zipCode').value     = a.zipCode;
            document.getElementById('country').value     = a.country;
            await loadStates();
            document.getElementById('state').value       = a.state;
            document.getElementById('edit-actions').classList.add('show');
            showAlert('info','Edit Mode','You are now editing an existing address.');
        } else { showAlert('error','Error',data.message); }
    } catch (e) { showAlert('error','Error','Failed to load address details'); }
}

function deleteAddress(event, addressId) {
    event.stopPropagation();
    Swal.fire({
        title:'Delete Address?', text:'This action cannot be undone.', icon:'warning',
        showCancelButton:true, confirmButtonColor:'#e74c3c', cancelButtonColor:'#6c757d',
        confirmButtonText:'Yes, Delete', cancelButtonText:'Cancel',
        customClass:{ popup:'custom-swal-popup' }
    }).then(async result => {
        if (!result.isConfirmed) return;
        try {
            const res  = await fetch(`/user/checkout/address/${addressId}`,{ method:'DELETE', headers:{'Content-Type':'application/json'} });
            const data = await res.json();
            if (data.success) {
                const card = document.querySelector(`input[value="${addressId}"]`)?.closest('.saved-address-card');
                if (card) {
                    card.style.transition = 'all .3s'; card.style.opacity = '0'; card.style.transform = 'translateY(-20px)';
                    setTimeout(() => {
                        card.remove();
                        const remaining = document.querySelectorAll('.saved-address-card');
                        if (remaining.length === 0) { toggleAddressMode('new'); }
                        else { remaining[0].querySelector('input[type="radio"]').checked = true; remaining[0].classList.add('selected'); }
                    }, 300);
                }
                showAlert('success','Deleted!',data.message);
            } else { showAlert('error','Error',data.message); }
        } catch (e) { showAlert('error','Error','Failed to delete address'); }
    });
}

async function saveEditedAddress() {
    const name     = document.getElementById('firstName').value.trim();
    const phone    = document.getElementById('phone').value.trim();
    const addr     = document.getElementById('address').value.trim();
    const city     = document.getElementById('city').value.trim();
    const state    = document.getElementById('state').value.trim();
    const zipCode  = document.getElementById('zipCode').value.trim();
    const country  = document.getElementById('country').value.trim();
    const addrType = document.getElementById('addressType').value;

    if (!name||!phone||!addr||!city||!state||!zipCode||!country) { showAlert('error','Error','Please fill in all required fields'); return; }
    if (!/^\d{10}$/.test(phone.replace(/\D/g,'')))  { showAlert('error','Error','Please enter a valid 10-digit phone number'); return; }
    if (!/^\d{5,6}$/.test(zipCode)) { showAlert('error','Error','Please enter a valid zip code'); return; }

    try {
        const url    = currentEditId ? `/user/checkout/address/${currentEditId}` : '/user/checkout/address';
        const method = currentEditId ? 'PUT' : 'POST';
        const res    = await fetch(url,{ method, headers:{'Content-Type':'application/json'}, body: JSON.stringify({ addressType:addrType, name, phone, address:addr, city, state, zipCode, country }) });
        const data   = await res.json();
        if (data.success) { showAlert('success','Success!',data.message); setTimeout(() => location.reload(), 1500); }
        else { showAlert('error','Error',data.message); }
    } catch (e) { showAlert('error','Error','Failed to save address'); }
}

function cancelEdit() {
    document.getElementById('edit-actions').classList.remove('show');
    document.querySelector('.new-address-container').classList.remove('show');
    document.querySelector('.saved-addresses-container').classList.add('show');
    document.getElementById('addressType').value = 'Home';
    document.getElementById('firstName').value   = '<%= user ? user.name : "" %>';
    document.getElementById('phone').value       = '<%= user ? user.phone : "" %>';
    document.getElementById('address').value     = '';
    document.getElementById('city').value        = '';
    document.getElementById('state').value       = '';
    document.getElementById('zipCode').value     = '';
    document.getElementById('country').value     = 'India';
    const btns = document.querySelectorAll('.address-toggle-btn');
    btns.forEach(b => b.classList.remove('active'));
    btns[0].classList.add('active');
    currentEditId = null;
    loadStates();
}

async function loadStates() {
    const country = document.getElementById('country').value;
    const sel     = document.getElementById('state');
    sel.innerHTML = '<option value="">Select State</option>';
    if (country && countryStateData[country]) {
        countryStateData[country].forEach(s => {
            const o = document.createElement('option');
            o.value = o.textContent = s;
            sel.appendChild(o);
        });
    }
}


function selectPayment(method, event) {
    event.stopPropagation();
    document.querySelectorAll('.payment-option').forEach(o => o.classList.remove('selected'));
    event.currentTarget.classList.add('selected');
    const radio = document.querySelector(`input[name="paymentMethod"][value="${method}"]`);
    if (radio) radio.checked = true;
}

async function fetchWalletBalance() {
    try {
        const res  = await fetch('/api/wallet/balance');
        const data = await res.json();
        const bal  = data.success ? data.balance : 0;
        window._walletBalance = bal;   // ← ADD THIS LINE ONLY
        document.getElementById('walletBalanceDisplay').textContent = `₹${bal.toFixed(2)}`;
        if (bal <= 0) {
            const wo = document.getElementById('wallet-option');
            wo.style.opacity = '0.5'; wo.style.cursor = 'not-allowed'; wo.style.pointerEvents = 'none';
            document.getElementById('walletBalanceDisplay').style.color = '#dc3545';
        }
    } catch (e) { document.getElementById('walletBalanceDisplay').textContent = '₹0.00'; }
}


function updateSummaryPrices(data) {
    // data: { subtotal, shipping, tax, totalPrice, discount, finalAmount }
    document.getElementById('summaryShipping').textContent = `₹${(data.shipping || 0).toFixed(2)}`;
    document.getElementById('summaryTotal').textContent    = `₹${(data.finalAmount).toFixed(2)}`;

    const discRow = document.getElementById('summaryDiscountRow');
    if (data.discount && data.discount > 0) {
        document.getElementById('summaryDiscount').textContent = `₹${data.discount.toFixed(2)}`;
        discRow.style.display = 'flex';
    } else {
        discRow.style.display = 'none';
    }
}

async function applyCoupon() {
    const code = document.getElementById('couponCodeInput').value.trim().toUpperCase();
    if (!code) { showAlert('error','Error','Please enter a coupon code'); return; }

    try {
        const res  = await fetch('/api/coupons/apply', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ couponCode: code })
        });
        const data = await res.json();

        if (data.success) {
            appliedCouponCode = data.couponCode;

            // Show applied badge, hide input row
            document.getElementById('appliedCouponCode').textContent  = data.couponCode;
            document.getElementById('appliedCouponSaving').textContent = `You saved ₹${data.discount.toFixed(2)}!`;
            document.getElementById('couponAppliedBadge').classList.add('show');
            document.getElementById('couponInputRow').style.display = 'none';

            updateSummaryPrices(data);
            showAlert('success','Coupon Applied!', data.message);
        } else {
            showAlert('error','Invalid Coupon', data.message);
        }
    } catch (e) { showAlert('error','Error','Failed to apply coupon. Please try again.'); }
}

async function removeCoupon() {
    try {
        const res  = await fetch('/api/coupons/remove', { method:'POST' });
        const data = await res.json();

        if (data.success) {
            appliedCouponCode = '';

            document.getElementById('couponAppliedBadge').classList.remove('show');
            document.getElementById('couponInputRow').style.display = 'flex';
            document.getElementById('couponCodeInput').value = '';

            updateSummaryPrices(data);
            showAlert('success','Removed','Coupon removed successfully.');
        }
    } catch (e) { showAlert('error','Error','Failed to remove coupon.'); }
}


async function openCouponModal() {
    document.getElementById('couponModalOverlay').classList.add('show');
    const body = document.getElementById('couponModalBody');
    body.innerHTML = '<div class="no-coupons"><i class="fas fa-spinner fa-spin" style="font-size:2rem;color:#D4B896;"></i><p style="margin-top:10px;">Loading coupons...</p></div>';

    try {
        const res  = await fetch('/api/coupons/available');
        const data = await res.json();

        if (!data.success || !data.coupons || data.coupons.length === 0) {
            body.innerHTML = `
                <div class="no-coupons">
                    <i class="fas fa-tag"></i>
                    <p>No coupons available right now.</p>
                    <p style="font-size:12px;color:#bbb;margin-top:5px;">Check back later for exciting offers!</p>
                </div>`;
            return;
        }

        body.innerHTML = data.coupons.map(c => {
            const expiry = new Date(c.expireOn).toLocaleDateString('en-IN',{ day:'numeric', month:'short', year:'numeric' });
            if (c.eligible) {
                return `
                <div class="coupon-card eligible">
                    <div class="coupon-card-top">
                        <span class="coupon-name">${c.name}</span>
                        <span class="coupon-discount-badge">
    ${c.discountType === 'percentage' 
        ? `${c.offerPrice}% OFF (save ₹${c.discountAmount})` 
        : `₹${c.offerPrice} OFF`}
</span>
                    </div>
                    <div class="coupon-card-meta">
                        <span><i class="fas fa-shopping-cart"></i> Min. ₹${c.minimumPrice}</span>
                        <span><i class="fas fa-calendar-alt"></i> Expires ${expiry}</span>
                    </div>
                    <button class="use-coupon-btn" onclick="useCouponFromModal('${c.name}')">
                        <i class="fas fa-check"></i> Apply This Coupon
                    </button>
                </div>`;
            } else {
                return `
                <div class="coupon-card ineligible">
                    <div class="coupon-card-top">
                        <span class="coupon-name">${c.name}</span>
                        <span class="coupon-discount-badge" style="background:#ccc;">₹${c.offerPrice} OFF</span>
                    </div>
                    <div class="coupon-card-meta">
                        <span><i class="fas fa-shopping-cart"></i> Min. ₹${c.minimumPrice}</span>
                        <span><i class="fas fa-calendar-alt"></i> Expires ${expiry}</span>
                    </div>
                    <span class="ineligible-notice">
                        <i class="fas fa-info-circle"></i>
                        Add ₹${(c.minimumPrice - data.subtotal).toFixed(2)} more to use this coupon
                    </span>
                </div>`;
            }
        }).join('');

    } catch (e) {
        body.innerHTML = '<div class="no-coupons"><i class="fas fa-exclamation-circle" style="color:#e74c3c;"></i><p>Failed to load coupons.</p></div>';
    }
}

function useCouponFromModal(code) {
    closeCouponModal();
    document.getElementById('couponCodeInput').value = code;
    applyCoupon();
}

function closeCouponModal() { document.getElementById('couponModalOverlay').classList.remove('show'); }
function closeCouponModalOnOverlay(e) { if (e.target === document.getElementById('couponModalOverlay')) closeCouponModal(); }


document.getElementById('checkout-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    if (!validateForm()) return;

    const placeOrderBtn = document.getElementById('place-order-btn');
    placeOrderBtn.disabled = true;
    placeOrderBtn.querySelector('.btn-text').style.display = 'none';
    placeOrderBtn.querySelector('.loading').style.display  = 'flex';

      const validateRes  = await fetch('/checkout/validate-cart', { method: 'POST' });
    const validateData = await validateRes.json();
    if (!validateData.success) {
        showAlert('error', 'Cannot Place Order', validateData.message);
        placeOrderBtn.disabled = false;
        placeOrderBtn.querySelector('.btn-text').style.display = '';
        placeOrderBtn.querySelector('.loading').style.display  = 'none';
        return;
    }

    const payment   = document.querySelector('input[name="paymentMethod"]:checked');
    const formData  = new FormData();
    const isNewAddr = document.getElementById('new-address').classList.contains('show');

    if (!isNewAddr) {
        const sel = document.querySelector('input[name="selectedAddress"]:checked');
        if (sel) formData.append('selectedAddress', sel.value);
    } else {
        ['addressType','firstName','phone','address','city','state','zipCode','country'].forEach(f => {
            const el = document.getElementById(f);
            if (el) formData.append(f, el.value);
        });
    }

    formData.append('paymentMethod', payment ? payment.value : 'cod');

    const notes = document.getElementById('orderNotes').value;
    if (notes) formData.append('orderNotes', notes);

    if (appliedCouponCode) formData.append('couponCode', appliedCouponCode);

// ── Razorpay flow ──
    if (payment && payment.value === 'razorpay') {
        try {

            const validateRes  = await fetch('/checkout/validate-cart', { method: 'POST' });
        const validateData = await validateRes.json();

        if (!validateData.success) {
            showAlert('error', 'Cannot Place Order', validateData.message);
            placeOrderBtn.disabled = false;
            placeOrderBtn.querySelector('.btn-text').style.display = '';
            placeOrderBtn.querySelector('.loading').style.display  = 'none';
            return;
        }
            const totalText   = document.getElementById('summaryTotal').innerText.replace('₹','').replace(/,/g,'');
            const totalAmount = Math.round(parseFloat(totalText) * 100);

            const res  = await fetch('/create-order', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ amount: totalAmount })
            });
            const data = await res.json();

            if (!data.success) {
                showAlert('error', 'Payment Error', 'Could not create payment order');
                placeOrderBtn.disabled = false;
                placeOrderBtn.querySelector('.btn-text').style.display = '';
                placeOrderBtn.querySelector('.loading').style.display  = 'none';
                return;
            }

            const options = {
                key:         '<%= process.env.RAZORPAY_KEY_ID %>',
                amount:      data.order.amount,
                currency:    'INR',
                name:        'Doodle Kiddys',
                description: 'Order Payment',
                order_id:    data.order.id,
                handler: async function(response) {
                    formData.append('razorpay_payment_id', response.razorpay_payment_id);
                    formData.append('razorpay_order_id',   response.razorpay_order_id);
                    formData.append('razorpay_signature',  response.razorpay_signature);

                    const orderRes  = await fetch('/checkout/process', {
                        method: 'POST',
                        body:   formData
                    });
                    const orderData = await orderRes.json();

                  if (orderData.success) {
                        window.location.href = '/order-success';
                    } else {
                        const couponParam = appliedCouponCode ? `&coupon=${encodeURIComponent(appliedCouponCode)}` : '';
                        window.location.href = `/order-failed?reason=${encodeURIComponent(orderData.message || 'Payment failed')}${couponParam}`;
                    }
                },
                prefill: {
                    name:  '<%= user ? user.name : "" %>',
                    email: '<%= user ? user.email : "" %>'
                },
              theme: { color: '#D4B896' },
                modal: {
                    ondismiss: function() {
                        const couponParam = appliedCouponCode ? `&coupon=${encodeURIComponent(appliedCouponCode)}` : '';
                        window.location.href = `/order-failed?reason=Payment+was+cancelled${couponParam}`;
                    }
                }
            };

            const rzp = new Razorpay(options);
            rzp.open();

        } catch (err) {
            console.error('Razorpay error:', err);
            window.location.href = '/order-failed?reason=Payment+processing+error';
        }
        return; // stop here for razorpay
    }
if (payment && (payment.value === 'cod') ) {
    const totalText   = document.getElementById('summaryTotal').innerText.replace('₹','').replace(/,/g,'');
    const totalAmount = parseFloat(totalText);
    if (totalAmount > 1000) {
        showAlert('error', 'COD Not Available', 'Cash on Delivery is not available for orders above ₹10,00. Please use online payment.');
        placeOrderBtn.disabled = false;
        placeOrderBtn.querySelector('.btn-text').style.display = '';
        placeOrderBtn.querySelector('.loading').style.display  = 'none';
        return;
    }
}
 if (payment && payment.value === 'wallet') {
    const walletBal  = window._walletBalance || 0;
    const totalText  = document.getElementById('summaryTotal').innerText.replace('₹','').replace(/,/g,'');
    const orderTotal = parseFloat(totalText);

    if (walletBal < orderTotal) {
        openHybridModal(orderTotal, walletBal, formData);
        return;
    }
}
    try {
        const res  = await fetch('/checkout/process', { method: 'POST', body: formData });
        const data = await res.json();

if (data.success) {
    Swal.fire({
        icon: 'success',
        title: ' Order Placed!',
        text: 'Your order has been placed successfully. Redirecting...',
        confirmButtonColor: '#D4B896',
        timer: 2500,
        timerProgressBar: true,
        showConfirmButton: false,
        customClass: { popup: 'custom-swal-popup' }
    }).then(() => {
        window.location.href = '/order-success';
    });
    // Re-enable button while alert shows
    placeOrderBtn.disabled = false;
    placeOrderBtn.querySelector('.btn-text').style.display = '';
    placeOrderBtn.querySelector('.loading').style.display  = 'none';
} else {
        window.location.href = `/order-failed?reason=${encodeURIComponent(data.message || 'Could not place order')}`;
    }
} catch (err) {
    window.location.href = '/order-failed?reason=Something+went+wrong';
}
});

function validateForm() {
    let valid = true;
    const isNew = document.getElementById('new-address').classList.contains('show');

    if (isNew) {
        ['firstName','phone','address','city','state','zipCode','country'].forEach(f => {
            const el  = document.getElementById(f);
            const err = document.getElementById(f + '-error');
            if (err && !el.value.trim()) { err.textContent = 'This field is required'; err.style.display = 'block'; valid = false; }
            else if (err) { err.style.display = 'none'; }
        });
        if (!/^\d{10}$/.test(document.getElementById('phone').value.replace(/\D/g,''))) {
            const e = document.getElementById('phone-error');
            if (e) { e.textContent = 'Please enter a valid 10-digit phone number'; e.style.display = 'block'; }
            valid = false;
        }
        if (!/^\d{5,6}$/.test(document.getElementById('zipCode').value)) {
            const e = document.getElementById('zipCode-error');
            if (e) { e.textContent = 'Please enter a valid zip code'; e.style.display = 'block'; }
            valid = false;
        }
    } else {
        if (!document.querySelector('input[name="selectedAddress"]:checked')) {
            showAlert('error','Error','Please select an address');
            valid = false;
        }
    }

    const payment = document.querySelector('input[name="paymentMethod"]:checked');
    if (!payment) { showAlert('error','Error','Please select a payment method'); valid = false; }

 
    return valid;
}

document.getElementById('phone').addEventListener('input', e => {
    let v = e.target.value.replace(/\D/g,'');
    if (v.length > 6) v = v.substring(0,3)+'-'+v.substring(3,6)+'-'+v.substring(6,10);
    else if (v.length > 3) v = v.substring(0,3)+'-'+v.substring(3);
    e.target.value = v;
});
document.getElementById('zipCode').addEventListener('input', e => { e.target.value = e.target.value.replace(/\D/g,'').substring(0,6); });

function showAlert(type, title, text) {
    Swal.fire({ icon:type, title, text, confirmButtonColor:'#D4B896', customClass:{ popup:'custom-swal-popup', confirmButton:'custom-swal-confirm-btn' } });
}

let _hybridFormData = null;

function openHybridModal(orderTotal, walletBal, formData) {
    const codAmt = orderTotal - walletBal;
    document.getElementById('hybridOrderTotal').textContent = `₹${orderTotal.toFixed(2)}`;
    document.getElementById('hybridWalletBal').textContent  = `₹${walletBal.toFixed(2)}`;
    document.getElementById('hybridCodAmount').textContent  = `₹${codAmt.toFixed(2)}`;
    document.getElementById('hybridCodBtn').textContent     = `₹${codAmt.toFixed(2)}`;
    document.getElementById('hybridDescription').textContent =
        `₹${walletBal.toFixed(2)} will be debited from your wallet now. You pay ₹${codAmt.toFixed(2)} in cash when the order arrives.`;
    _hybridFormData = formData;
    document.getElementById('walletHybridModal').style.display = 'flex';
}

function closeHybridModal() {
    document.getElementById('walletHybridModal').style.display = 'none';
    _hybridFormData = null;
    const btn = document.getElementById('place-order-btn');
    btn.disabled = false;
    btn.querySelector('.btn-text').style.display = '';
    btn.querySelector('.loading').style.display  = 'none';
}

async function confirmHybridPayment() {
    if (!_hybridFormData) return;
    document.getElementById('walletHybridModal').style.display = 'none';
    _hybridFormData.set('paymentMethod', 'wallet+cod');

    try {
        const res  = await fetch('/checkout/process', { method: 'POST', body: _hybridFormData });
        const data = await res.json();

        if (data.success) {
            Swal.fire({
                icon: 'success',
                title: 'Order Placed!',
                text: 'Redirecting...',
                confirmButtonColor: '#D4B896',
                timer: 2500,
                timerProgressBar: true,
                showConfirmButton: false,
                customClass: { popup: 'custom-swal-popup' }
            }).then(() => { window.location.href = '/order-success'; });
        } else {
    window.location.href = `/order-failed?reason=${encodeURIComponent(data.message || 'Could not place order')}`;
}
    } catch (err) {
        showAlert('error', 'Error', 'Something went wrong. Please try again.');
    } finally {
        _hybridFormData = null;
        const btn = document.getElementById('place-order-btn');
        btn.disabled = false;
        btn.querySelector('.btn-text').style.display = '';
        btn.querySelector('.loading').style.display  = 'none';
    }
}

document.addEventListener('DOMContentLoaded', () => {
    if (document.getElementById('new-address').classList.contains('show')) loadStates();
    fetchWalletBalance();
    // Disable COD if order total > 1000
const totalText = document.getElementById('summaryTotal').innerText.replace('₹','').replace(/,/g,'');
const orderTotal = parseFloat(totalText);
if (orderTotal > 1000) {
    const codOption = document.getElementById('cod-option');
    codOption.style.opacity = '0.5';
    codOption.style.cursor = 'not-allowed';
    codOption.style.pointerEvents = 'none';
    document.getElementById('cod-desc').textContent = 'Not available for orders above ₹1,000';
    document.getElementById('cod-desc').style.color = '#e74c3c';

    // If COD was somehow selected, switch to razorpay
    const codRadio = document.querySelector('input[name="paymentMethod"][value="cod"]');
    if (codRadio && codRadio.checked) {
        codRadio.checked = false;
        document.querySelector('input[name="paymentMethod"][value="razorpay"]').checked = true;
        document.querySelectorAll('.payment-option').forEach(o => o.classList.remove('selected'));
        document.querySelector('.payment-option').classList.add('selected');
    }
}

    document.querySelectorAll('.checkout-header,.progress-steps,.checkout-form,.order-summary').forEach((el,i) => {
        el.style.opacity = '0'; el.style.transform = 'translateY(30px)';
        setTimeout(() => { el.style.transition = 'all .6s ease'; el.style.opacity = '1'; el.style.transform = 'translateY(0)'; }, i * 150);
    });

    document.querySelectorAll('input, select, textarea').forEach(input => {
        input.addEventListener('blur', function() {
            const err = document.getElementById(this.id + '-error');
            if (err) {
                if (this.hasAttribute('required') && !this.value.trim()) { err.textContent = 'This field is required'; err.style.display = 'block'; }
                else err.style.display = 'none';
            }
        });
    });
    document.querySelectorAll('input').forEach(i => i.addEventListener('keypress', e => { if (e.key === 'Enter') e.preventDefault(); }));
    document.getElementById('couponCodeInput').addEventListener('keypress', e => { if (e.key === 'Enter') { e.preventDefault(); applyCoupon(); } });
    
       <% if (typeof pendingCoupon !== 'undefined' && pendingCoupon) { %>
    setTimeout(async () => {
        document.getElementById('couponCodeInput').value = '<%= pendingCoupon %>';
        await applyCoupon();
    }, 800);
<% } %>
});

async function saveNewAddress() {
    const name     = document.getElementById('firstName').value.trim();
    const phone    = document.getElementById('phone').value.trim();
    const addr     = document.getElementById('address').value.trim();
    const city     = document.getElementById('city').value.trim();
    const state    = document.getElementById('state').value.trim();
    const zipCode  = document.getElementById('zipCode').value.trim();
    const country  = document.getElementById('country').value.trim();
    const addrType = document.getElementById('addressType').value;

    // Validate
    if (!name || !addr || !city || !state || !zipCode || !country) {
        showAlert('error', 'Error', 'Please fill in all required fields');
        return;
    }
    if (!/^\d{10}$/.test(phone.replace(/\D/g, ''))) {
        showAlert('error', 'Error', 'Please enter a valid 10-digit phone number');
        return;
    }
    if (!/^\d{5,6}$/.test(zipCode)) {
        showAlert('error', 'Error', 'Please enter a valid zip code');
        return;
    }

    try {
        const res  = await fetch('/user/checkout/address', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ addressType: addrType, name, phone, address: addr, city, state, zipCode, country })
        });
        const data = await res.json();

        if (data.success) {
            showAlert('success', 'Address Saved!', 'Your address has been saved successfully.');
            setTimeout(() => location.reload(), 1500);
        } else {
            showAlert('error', 'Error', data.message);
        }
    } catch (e) {
        showAlert('error', 'Error', 'Failed to save address. Please try again.');
    }
}
</script>
