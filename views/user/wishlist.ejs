<%- include("../../views/partials/user/header") %>

<style>
    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background-color: #f8f9fa;
    }

    .wishlist-container {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 2rem;
    }

    .wishlist-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .wishlist-title {
        font-size: 2rem;
        font-weight: bold;
        color: #333;
    }

    .wishlist-count {
        font-size: 0.9rem;
        color: #888;
        background: #f0e8e0;
        padding: 0.3rem 0.9rem;
        border-radius: 20px;
        transition: all 0.3s;
    }

    .wishlist-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 2rem;
    }

    .product-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: transform 0.3s, box-shadow 0.3s, opacity 0.4s;
        position: relative;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    /* slide-in animation for refilled cards */
    @keyframes slideInUp {
        from { opacity: 0; transform: translateY(30px) scale(0.96); }
        to   { opacity: 1; transform: translateY(0)   scale(1);    }
    }
    .card-slide-in {
        animation: slideInUp 0.4s ease forwards;
    }

    .new-badge {
        position: absolute;
        top: 0.75rem;
        left: 0.75rem;
        background: #D4B49B;
        color: white;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 2px 10px;
        border-radius: 20px;
        z-index: 2;
        letter-spacing: 0.5px;
    }

    .product-image {
        width: 100%;
        height: 220px;
        object-fit: cover;
        display: block;
    }

    .product-info { padding: 1rem; }

    .product-title {
        font-size: 1rem;
        font-weight: bold;
        margin-bottom: 0.3rem;
        color: #333;
    }

    .added-date {
        font-size: 0.72rem;
        color: #aaa;
        margin-bottom: 0.5rem;
    }

    .product-price {
        color: #D4B49B;
        font-weight: bold;
        margin-bottom: 1rem;
    }

    .actions { display: flex; gap: 0.5rem; }

    .btn {
        flex: 1;
        padding: 0.5rem;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-cart { background: linear-gradient(#dec7aa, #e5c39f); color: white; }
    .btn-cart:hover { opacity: 0.9; }
    .btn-remove { background: #ef4444; color: white; }
    .btn-remove:hover { background: #dc2626; }

    .empty {
        text-align: center;
        margin-top: 5rem;
        color: #666;
    }
    .empty h3 { font-size: 1.5rem; margin-bottom: 1rem; }

    /* ── PAGINATION ── */
    .pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
        margin-top: 3rem;
        flex-wrap: wrap;
    }

    .page-btn {
        padding: 0.5rem 1rem;
        border: 1.5px solid #e4d7c8;
        border-radius: 10px;
        background: white;
        color: #a07850;
        font-weight: 600;
        font-size: 0.88rem;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }
    .page-btn:hover { background: #f0e8e0; border-color: #D4B49B; }
    .page-btn.active {
        background: linear-gradient(135deg, #D4B49B, #c9a587);
        color: white;
        border-color: #D4B49B;
        pointer-events: none;
    }
    .page-btn.disabled { opacity: 0.4; pointer-events: none; }
    .page-info { font-size: 0.85rem; color: #888; margin: 0 0.5rem; }
</style>

<div class="wishlist-container">

    <div class="wishlist-header">
        <h2 class="wishlist-title">My Wishlist ❤️</h2>
        <span class="wishlist-count" id="wishlistCount">
            <%= totalItems %> item<%= totalItems !== 1 ? 's' : '' %>
        </span>
    </div>

    <% if (!wishlist.products || wishlist.products.length === 0) { %>
        <div class="empty" id="emptyState">
            <h3>Your wishlist is empty</h3>
            <p>Add your favorite products here 💖</p>
            <a href="/shop" style="display:inline-block;margin-top:1.5rem;padding:0.7rem 2rem;
               background:linear-gradient(#dec7aa,#e5c39f);color:white;border-radius:25px;
               text-decoration:none;font-weight:600;">
                Browse Products
            </a>
        </div>
    <% } else { %>

        <div class="wishlist-grid" id="wishlistGrid">
            <% wishlist.products.forEach((item, index) => { %>
                <% const product = item.productId; %>
                <% if (!product) return; %>
                <%
                    const isNew = currentPage === 1 && index < 2;
                    let addedLabel = '';
                    if (item.addedAt) {
                        const d = new Date(item.addedAt);
                        addedLabel = d.toLocaleDateString('en-IN', {
                            day: 'numeric', month: 'short', year: 'numeric'
                        });
                    }
                %>
                <div class="product-card" data-id="<%= product._id %>">
                    <% if (isNew) { %><div class="new-badge">✦ NEW</div><% } %>
                    <a href="/product/<%= product._id %>">
                        <img src="/images/<%= product.productImage[0] %>"
                             class="product-image"
                             onerror="this.src='/images/placeholder.jpg'" />
                    </a>
                    <div class="product-info">
                        <h3 class="product-title"><%= product.productName %></h3>
                        <% if (addedLabel) { %>
                            <p class="added-date">Added <%= addedLabel %></p>
                        <% } %>
                        <p class="product-price">₹<%= product.salePrice || product.regularPrice %></p>
                        <div class="actions">
                            <button class="btn btn-cart"
                                onclick="addToCart('<%= product._id %>','<%= product.productName.replace(/'/g,"\\'") %>',this)">
                                Add to Cart
                            </button>
                            <button class="btn btn-remove"
                                onclick="removeFromWishlist('<%= product._id %>',this)">
                                Remove
                            </button>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- PAGINATION -->
        <div class="pagination" id="paginationContainer">
            <%- /* rendered by JS refreshPagination() after every removal too */ '' %>
        </div>

    <% } %>
</div>

<script>
/* ══════════════════════════════════════════════════════
   STATE — mirrors what the server rendered
   ══════════════════════════════════════════════════════ */
let _currentPage = <%= currentPage %>;
let _totalPages  = <%= totalPages %>;
let _totalItems  = <%= totalItems %>;
const LIMIT      = 8;

/* render pagination immediately on load */
refreshPagination(_currentPage, _totalPages);

/* ── NOTIFICATION ── */
function showNotification(message, type = 'success') {
    let msg = document.getElementById('statusMsg');
    if (!msg) {
        msg = document.createElement('div');
        msg.id = 'statusMsg';
        msg.style.cssText = `
            position:fixed;bottom:2rem;left:50%;
            transform:translateX(-50%) translateY(20px);
            color:white;padding:0.6rem 1.4rem;border-radius:25px;
            font-size:0.88rem;font-weight:500;opacity:0;
            transition:opacity 0.3s,transform 0.3s;
            z-index:9999;white-space:nowrap;pointer-events:none;`;
        document.body.appendChild(msg);
    }
    msg.style.background = type === 'success' ? '#2d6a4f' : '#c0392b';
    msg.textContent = message;
    void msg.offsetWidth;
    msg.style.opacity = '1';
    msg.style.transform = 'translateX(-50%) translateY(0)';
    clearTimeout(msg._t);
    msg._t = setTimeout(() => {
        msg.style.opacity = '0';
        msg.style.transform = 'translateX(-50%) translateY(20px)';
    }, 2800);
}

/* ── BUILD A CARD FROM JSON DATA ── */
function buildCard(item) {
    const price      = item.salePrice || item.regularPrice || 0;
    const imageSrc   = item.image ? `/images/${item.image}` : '/images/placeholder.jpg';
    const safeName   = item.productName.replace(/'/g, "\\'");
    let addedLabel   = '';
    if (item.addedAt) {
        addedLabel = new Date(item.addedAt).toLocaleDateString('en-IN', {
            day: 'numeric', month: 'short', year: 'numeric'
        });
    }

    const card = document.createElement('div');
    card.className = 'product-card card-slide-in';
    card.dataset.id = item.productId;
    card.innerHTML = `
        <a href="/product/${item.productId}">
            <img src="${imageSrc}" class="product-image"
                 onerror="this.src='/images/placeholder.jpg'" />
        </a>
        <div class="product-info">
            <h3 class="product-title">${item.productName}</h3>
            ${addedLabel ? `<p class="added-date">Added ${addedLabel}</p>` : ''}
            <p class="product-price">₹${price}</p>
            <div class="actions">
                <button class="btn btn-cart"
                    onclick="addToCart('${item.productId}','${safeName}',this)">
                    Add to Cart
                </button>
                <button class="btn btn-remove"
                    onclick="removeFromWishlist('${item.productId}',this)">
                    Remove
                </button>
            </div>
        </div>`;
    return card;
}

/* ── REFILL: fetch current page from API and patch the grid ── */
async function refillGrid() {
    try {
        const res  = await fetch(`/api/wishlist?page=${_currentPage}`);
        const data = await res.json();
        if (!data.success) return;

        // Update global state
        _totalItems = data.totalItems;
        _totalPages = data.totalPages;

        // Recalculate page if current page is now out of range
        if (_currentPage > _totalPages) {
            _currentPage = _totalPages;
            // Redirect to corrected page
            window.location.href = `/wishlist?page=${_currentPage}`;
            return;
        }

        const grid = document.getElementById('wishlistGrid');
        if (!grid) return;

        // IDs currently shown in the grid
        const shownIds = new Set(
            [...grid.querySelectorAll('.product-card')].map(c => c.dataset.id)
        );

        // IDs that should be on this page after removal
        const serverIds = new Set(data.items.map(i => String(i.productId)));

        // Add cards that are on server but not yet in grid (refill from next page)
        data.items.forEach(item => {
            if (!shownIds.has(String(item.productId))) {
                const newCard = buildCard(item);
                grid.appendChild(newCard);
            }
        });

        // Update count badge
        const countEl = document.getElementById('wishlistCount');
        if (countEl) {
            countEl.textContent = `${_totalItems} item${_totalItems !== 1 ? 's' : ''}`;
        }

        // If grid is now empty show empty state
        const remaining = grid.querySelectorAll('.product-card');
        if (remaining.length === 0 || _totalItems === 0) {
            showEmptyState();
            return;
        }

        // Re-render pagination
        refreshPagination(_currentPage, _totalPages);

    } catch (err) {
        console.error('refillGrid error:', err);
    }
}

/* ── SHOW EMPTY STATE ── */
function showEmptyState() {
    const container = document.querySelector('.wishlist-container');
    const grid      = document.getElementById('wishlistGrid');
    const pagination = document.getElementById('paginationContainer');
    if (grid)       grid.remove();
    if (pagination) pagination.remove();

    const empty = document.createElement('div');
    empty.className = 'empty';
    empty.innerHTML = `
        <h3>Your wishlist is empty</h3>
        <p>Add your favorite products here 💖</p>
        <a href="/shop" style="display:inline-block;margin-top:1.5rem;padding:0.7rem 2rem;
           background:linear-gradient(#dec7aa,#e5c39f);color:white;border-radius:25px;
           text-decoration:none;font-weight:600;">
            Browse Products
        </a>`;
    container.appendChild(empty);

    const countEl = document.getElementById('wishlistCount');
    if (countEl) countEl.style.display = 'none';
}

/* ── PAGINATION RENDERER ── */
function refreshPagination(current, total) {
    const container = document.getElementById('paginationContainer');
    if (!container) return;

    if (total <= 1) { container.innerHTML = ''; return; }

    let html = '';

    // Prev button
    html += `<a href="/wishlist?page=${current - 1}"
                class="page-btn ${current === 1 ? 'disabled' : ''}"
                onclick="handlePageClick(event, ${current - 1})">← Prev</a>`;

    // Page numbers with ellipsis
    for (let p = 1; p <= total; p++) {
        if (p === 1 || p === total || (p >= current - 1 && p <= current + 1)) {
            html += `<a href="/wishlist?page=${p}"
                        class="page-btn ${p === current ? 'active' : ''}"
                        onclick="handlePageClick(event, ${p})">${p}</a>`;
        } else if (p === current - 2 || p === current + 2) {
            html += `<span class="page-info">…</span>`;
        }
    }

    // Next button
    html += `<a href="/wishlist?page=${current + 1}"
                class="page-btn ${current === total ? 'disabled' : ''}"
                onclick="handlePageClick(event, ${current + 1})">Next →</a>`;

    container.innerHTML = html;
}

function handlePageClick(e, page) {
    e.preventDefault();
    window.location.href = `/wishlist?page=${page}`;
}

/* ── REMOVE FROM WISHLIST ── */
function removeFromWishlist(productId, btn) {
    btn.innerText = 'Removing...';
    btn.disabled  = true;

    fetch(`/removeWishlist/${productId}`, { method: 'POST' })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const card = btn.closest('.product-card');

                // Animate out
                card.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
                card.style.opacity    = '0';
                card.style.transform  = 'scale(0.92)';

                setTimeout(() => {
                    card.remove();
                    // After removal, refill from next page if needed
                    refillGrid();
                }, 370);

                showNotification('Removed from wishlist', 'success');
            } else {
                btn.innerText = 'Remove';
                btn.disabled  = false;
                showNotification(data.message || 'Failed to remove', 'error');
            }
        })
        .catch(() => {
            btn.innerText = 'Remove';
            btn.disabled  = false;
            showNotification('Something went wrong', 'error');
        });
}

/* ── ADD TO CART (checks options first) ── */
function addToCart(productId, name, btn) {
    btn.innerText = 'Checking...';
    btn.disabled  = true;

    fetch(`/product/options/${productId}`)
        .then(r => r.json())
        .then(data => {
            if (!data.success) throw new Error('Failed to load product');

            const sizes  = Array.isArray(data.sizes)  ? data.sizes  : [];
            const colors = Array.isArray(data.colors) ? data.colors : [];
            const hasOptions = sizes.length > 1 || colors.length > 1;

            btn.innerText = 'Add to Cart';
            btn.disabled  = false;

            hasOptions
                ? showOptionsModal(productId, name, sizes, colors, btn)
                : doAddToCart(productId, name, null, null, btn);
        })
        .catch(() => {
            btn.innerText = 'Add to Cart';
            btn.disabled  = false;
            showNotification('Could not load product options', 'error');
        });
}

/* ── OPTIONS MODAL ── */
function showOptionsModal(productId, productName, sizes, colors, triggerBtn) {
    const existing = document.getElementById('wishlistOptionsModal');
    if (existing) existing.remove();

    const modal = document.createElement('div');
    modal.id = 'wishlistOptionsModal';
    modal.style.cssText = `
        position:fixed;inset:0;z-index:10000;
        background:rgba(0,0,0,0.5);backdrop-filter:blur(5px);
        display:flex;align-items:center;justify-content:center;`;

    modal.innerHTML = `
        <style>
            #wishlistOptionsModal .wl-box {
                background:white;border-radius:15px;width:90%;max-width:480px;
                box-shadow:0 10px 40px rgba(0,0,0,0.2);overflow:hidden;
            }
            #wishlistOptionsModal .wl-head {
                padding:1.5rem 2rem;border-bottom:1px solid #eee;
                display:flex;justify-content:space-between;align-items:center;
            }
            #wishlistOptionsModal .wl-head h3{margin:0;font-size:1.2rem;color:#333;}
            #wishlistOptionsModal .wl-pname{color:#D4B49B;font-size:0.85rem;margin-top:0.3rem;}
            #wishlistOptionsModal .wl-x{
                width:30px;height:30px;border-radius:6px;background:#f5f5f5;
                border:none;font-size:1.2rem;cursor:pointer;
                display:flex;align-items:center;justify-content:center;color:#666;
            }
            #wishlistOptionsModal .wl-x:hover{background:#eee;}
            #wishlistOptionsModal .wl-body{padding:1.5rem 2rem;}
            #wishlistOptionsModal .wl-label{
                display:block;font-size:0.85rem;font-weight:600;
                color:#333;margin-bottom:0.5rem;margin-top:1rem;
            }
            #wishlistOptionsModal .wl-label:first-child{margin-top:0;}
            #wishlistOptionsModal .wl-select{
                width:100%;padding:0.75rem 1rem;border:1px solid #ddd;
                border-radius:8px;font-size:0.95rem;color:#333;
                background:#fafafa;cursor:pointer;appearance:none;
            }
            #wishlistOptionsModal .wl-select:focus{outline:none;border-color:#D4B49B;}
            #wishlistOptionsModal .wl-foot{
                padding:1.5rem 2rem;background:#fafafa;
                border-top:1px solid #eee;display:flex;gap:1rem;
            }
            #wishlistOptionsModal .wl-btn{
                flex:1;padding:0.8rem;border:none;border-radius:8px;
                font-size:0.95rem;font-weight:600;cursor:pointer;transition:0.2s;
            }
            #wishlistOptionsModal .wl-cancel{background:white;color:#666;border:1px solid #ddd;}
            #wishlistOptionsModal .wl-cancel:hover{background:#f5f5f5;}
            #wishlistOptionsModal .wl-confirm{background:#D4B49B;color:white;}
            #wishlistOptionsModal .wl-confirm:hover{background:#c9a587;}
        </style>
        <div class="wl-box">
            <div class="wl-head">
                <div>
                    <h3>Select Options</h3>
                    <div class="wl-pname">${productName}</div>
                </div>
                <button class="wl-x" onclick="closeWLModal()">&times;</button>
            </div>
            <div class="wl-body">
                ${sizes.length > 1 ? `
                    <label class="wl-label">Size *</label>
                    <select class="wl-select" id="wlSize">
                        <option value="">Choose a size</option>
                        ${sizes.map(s => `<option value="${s}">${s}</option>`).join('')}
                    </select>` : ''}
                ${colors.length > 1 ? `
                    <label class="wl-label">Color *</label>
                    <select class="wl-select" id="wlColor">
                        <option value="">Choose a color</option>
                        ${colors.map(c => `<option value="${c}">${c}</option>`).join('')}
                    </select>` : ''}
            </div>
            <div class="wl-foot">
                <button class="wl-btn wl-cancel" onclick="closeWLModal()">Cancel</button>
                <button class="wl-btn wl-confirm"
                    onclick="confirmWLCart('${productId}','${productName.replace(/'/g,"\\'")}')">
                    Add to Cart
                </button>
            </div>
        </div>`;

    document.body.appendChild(modal);
    modal.addEventListener('click', e => { if (e.target === modal) closeWLModal(); });
}

function closeWLModal() {
    const m = document.getElementById('wishlistOptionsModal');
    if (m) { m.style.opacity = '0'; setTimeout(() => m.remove(), 250); }
}

function confirmWLCart(productId, productName) {
    const ss = document.getElementById('wlSize');
    const cs = document.getElementById('wlColor');

    if (ss && ss.options.length > 1 && !ss.value) {
        ss.style.borderColor = '#ef4444';
        showNotification('Please select a size', 'error'); return;
    }
    if (cs && cs.options.length > 1 && !cs.value) {
        cs.style.borderColor = '#ef4444';
        showNotification('Please select a color', 'error'); return;
    }

    closeWLModal();
    const btn = document.querySelector(`[data-id="${productId}"] .btn-cart`);
    doAddToCart(productId, productName, ss?.value || null, cs?.value || null, btn);
}

/* ── ACTUAL CART API CALL ── */
function doAddToCart(productId, productName, size, color, btn) {
    if (btn) { btn.innerText = 'Adding...'; btn.disabled = true; }

    fetch('/api/add-to-cart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, quantity: 1, size, color })
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            showNotification(`${productName} added to cart ✓`, 'success');
            if (window.updateCartCount) window.updateCartCount();

            // Remove card and refill
            const card = btn ? btn.closest('.product-card') : null;
            if (card) {
                card.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
                card.style.opacity    = '0';
                card.style.transform  = 'scale(0.92)';
                setTimeout(() => {
                    card.remove();
                    refillGrid();
                }, 370);
            }
        } else {
            if (btn) { btn.innerText = 'Add to Cart'; btn.disabled = false; }
            showNotification(data.message || 'Could not add to cart', 'error');
        }
    })
    .catch(() => {
        if (btn) { btn.innerText = 'Add to Cart'; btn.disabled = false; }
        showNotification('Something went wrong', 'error');
    });
}
</script>

<%- include("../../views/partials/user/footer") %>