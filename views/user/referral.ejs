<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Referral Program - Kids Fashion Store</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --tan:      #D4B896;
      --tan-dark: #b8956b;
      --tan-lite: #f5ede3;
      --tan-pale: #fdf8f3;
      --brown:    #6b4c2a;
      --text:     #2d2418;
      --muted:    #8a7060;
      --border:   #e8d8c8;
      --white:    #ffffff;
      --green:    #2ecc71;
      --red:      #e74c3c;
      --shadow:   0 4px 24px rgba(180,140,100,0.13);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--tan-pale);
      color: var(--text);
      min-height: 100vh;
    }

    /* ── NAV ── */
    .top-nav {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 0 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
      position: sticky; top: 0; z-index: 100;
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      color: var(--tan);
      text-decoration: none;
    }
    .nav-links { display: flex; gap: 24px; }
    .nav-links a {
      font-size: 14px;
      color: var(--muted);
      text-decoration: none;
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--tan-dark); }

    /* ── LAYOUT ── */
    .page-wrapper {
      max-width: 960px;
      margin: 40px auto;
      padding: 0 20px;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: var(--muted);
      text-decoration: none;
      margin-bottom: 28px;
      transition: color .2s;
    }
    .back-link:hover { color: var(--tan-dark); }

    /* ── HERO CARD ── */
    .hero-card {
      background: linear-gradient(135deg, var(--tan) 0%, var(--tan-dark) 100%);
      border-radius: 20px;
      padding: 44px 48px;
      color: var(--white);
      position: relative;
      overflow: hidden;
      margin-bottom: 28px;
    }
    .hero-card::before {
      content: '';
      position: absolute;
      top: -60px; right: -60px;
      width: 260px; height: 260px;
      background: rgba(255,255,255,0.07);
      border-radius: 50%;
    }
    .hero-card::after {
      content: '';
      position: absolute;
      bottom: -80px; right: 80px;
      width: 180px; height: 180px;
      background: rgba(255,255,255,0.05);
      border-radius: 50%;
    }
    .hero-tag {
      display: inline-block;
      background: rgba(255,255,255,0.2);
      border: 1px solid rgba(255,255,255,0.3);
      border-radius: 100px;
      padding: 4px 14px;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: .5px;
      margin-bottom: 16px;
    }
    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: 34px;
      line-height: 1.2;
      margin-bottom: 10px;
    }
    .hero-sub {
      font-size: 15px;
      opacity: .85;
      max-width: 480px;
      line-height: 1.6;
    }
    .hero-rewards {
      display: flex;
      gap: 24px;
      margin-top: 32px;
      flex-wrap: wrap;
    }
    .reward-pill {
      background: rgba(255,255,255,0.15);
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 12px;
      padding: 14px 22px;
      backdrop-filter: blur(4px);
    }
    .reward-pill .amount {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      font-weight: 700;
    }
    .reward-pill .label {
      font-size: 12px;
      opacity: .8;
      margin-top: 2px;
    }

    /* ── GRID ── */
    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 20px;
    }
    @media (max-width: 640px) { .grid-2 { grid-template-columns: 1fr; } }

    /* ── CARD ── */
    .card {
      background: var(--white);
      border-radius: 16px;
      padding: 28px;
      box-shadow: var(--shadow);
      border: 1px solid var(--border);
    }
    .card-title {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--muted);
      margin-bottom: 16px;
    }

    /* ── STATS ── */
    .stat-number {
      font-family: 'Playfair Display', serif;
      font-size: 40px;
      color: var(--tan-dark);
      line-height: 1;
    }
    .stat-label {
      font-size: 14px;
      color: var(--muted);
      margin-top: 4px;
    }
    .stat-row {
      display: flex;
      gap: 32px;
      flex-wrap: wrap;
    }
    .stat-item { flex: 1; min-width: 100px; }

    /* ── WALLET BLOCK ── */
    .wallet-balance-block {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .wallet-icon {
      width: 52px; height: 52px;
      background: var(--tan-lite);
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px;
      flex-shrink: 0;
    }
    .wallet-amount {
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      color: var(--brown);
    }
    .wallet-sub {
      font-size: 13px;
      color: var(--muted);
      margin-top: 2px;
    }
    .wallet-link {
      display: inline-block;
      margin-top: 14px;
      font-size: 13px;
      font-weight: 500;
      color: var(--tan-dark);
      text-decoration: none;
      border-bottom: 1px solid var(--tan);
      padding-bottom: 1px;
      transition: color .2s;
    }
    .wallet-link:hover { color: var(--brown); }

    /* ── CODE BOX ── */
    .code-display {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--tan-lite);
      border: 2px dashed var(--tan);
      border-radius: 12px;
      padding: 16px 20px;
      margin-bottom: 16px;
    }
    .code-text {
      font-family: 'Courier New', monospace;
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 3px;
      color: var(--brown);
      flex: 1;
    }
    .copy-btn {
      background: var(--tan);
      color: var(--white);
      border: none;
      border-radius: 8px;
      padding: 8px 16px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: background .2s, transform .1s;
      white-space: nowrap;
    }
    .copy-btn:hover { background: var(--tan-dark); }
    .copy-btn:active { transform: scale(.96); }
    .copy-btn.copied { background: var(--green); }

    /* ── LINK BOX ── */
    .link-box {
      background: var(--tan-pale);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 16px;
    }
    .link-url {
      font-size: 12px;
      color: var(--muted);
      flex: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .copy-link-btn {
      background: none;
      border: 1px solid var(--tan);
      color: var(--tan-dark);
      border-radius: 7px;
      padding: 6px 14px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all .2s;
      white-space: nowrap;
    }
    .copy-link-btn:hover { background: var(--tan); color: var(--white); }

    /* ── SHARE BUTTONS ── */
    .share-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .share-btn {
      flex: 1;
      min-width: 100px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 10px 16px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: transform .15s, opacity .2s;
      border: none;
    }
    .share-btn:hover { opacity: .88; transform: translateY(-1px); }
    .share-whatsapp { background: #25D366; color: #fff; }
    .share-copy     { background: var(--tan-lite); color: var(--brown); border: 1px solid var(--border); }

    /* ── HOW IT WORKS ── */
    .steps {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .step {
      display: flex;
      gap: 16px;
      padding: 16px 0;
      position: relative;
    }
    .step:not(:last-child)::after {
      content: '';
      position: absolute;
      left: 19px; top: 52px;
      width: 2px; bottom: 0;
      background: var(--border);
    }
    .step-num {
      width: 40px; height: 40px;
      background: var(--tan-lite);
      border: 2px solid var(--tan);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700;
      font-size: 14px;
      color: var(--tan-dark);
      flex-shrink: 0;
      z-index: 1;
      position: relative;
    }
    .step-body { padding-top: 6px; }
    .step-title { font-size: 14px; font-weight: 600; margin-bottom: 3px; }
    .step-desc  { font-size: 13px; color: var(--muted); line-height: 1.5; }

    /* ── COUPON CARD ── */
    .coupon-card {
      background: linear-gradient(135deg, #fff9f3 0%, #fdf0e0 100%);
      border: 2px dashed var(--tan);
      border-radius: 16px;
      padding: 24px 28px;
      margin-bottom: 20px;
      position: relative;
      overflow: hidden;
    }
    .coupon-card::before {
      content: '🎟';
      position: absolute;
      right: 24px; top: 50%;
      transform: translateY(-50%);
      font-size: 48px;
      opacity: .12;
    }
    .coupon-code-badge {
      display: inline-block;
      background: var(--tan);
      color: var(--white);
      font-family: 'Courier New', monospace;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: 2px;
      padding: 6px 18px;
      border-radius: 8px;
      margin-bottom: 10px;
    }
    .coupon-details {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.8;
    }
    .coupon-details strong { color: var(--brown); }

    /* ── EMPTY STATE ── */
    .empty-state {
      text-align: center;
      padding: 32px;
      color: var(--muted);
    }
    .empty-state .icon { font-size: 36px; margin-bottom: 10px; }
    .empty-state p { font-size: 14px; }

    /* ── TOAST ── */
    .toast {
      position: fixed;
      bottom: 30px; right: 30px;
      background: var(--brown);
      color: var(--white);
      padding: 12px 22px;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 500;
      opacity: 0;
      transform: translateY(12px);
      transition: all .3s;
      z-index: 999;
      pointer-events: none;
    }
    .toast.show { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      .hero-card { padding: 28px 24px; }
      .hero-title { font-size: 26px; }
      .hero-rewards { gap: 14px; }
      .page-wrapper { margin: 20px auto; }
    }
  </style>
</head>
<body>

<!-- ── Nav ── -->
<nav class="top-nav">
  <a href="/" class="nav-logo">Kids Fashion</a>
  <div class="nav-links">
    <a href="/shop">Shop</a>
    <a href="/profile">Profile</a>
    <a href="/cart">Cart</a>
  </div>
</nav>

<div class="page-wrapper">
  <a href="/profile" class="back-link">
    ← Back to Profile
  </a>

  <!-- ── Hero ── -->
  <div class="hero-card">
    <div class="hero-tag">🎁 Referral Program</div>
    <h1 class="hero-title">Share & Earn Together</h1>
    <p class="hero-sub">
      Invite friends to Kids Fashion Store. When they sign up using your code,
      you both get wallet credits instantly!
    </p>
    <div class="hero-rewards">
      <div class="reward-pill">
        <div class="amount">₹100</div>
        <div class="label">You earn per referral</div>
      </div>
      <div class="reward-pill">
        <div class="amount">₹50</div>
        <div class="label">Your friend's welcome bonus</div>
      </div>
    </div>
  </div>

  <!-- ── Wallet + Stats ── -->
  <div class="grid-2">

    <!-- Wallet balance -->
    <div class="card">
      <div class="card-title">💰 Your Wallet</div>
      <div class="wallet-balance-block">
        <div class="wallet-icon">👛</div>
        <div>
          <div class="wallet-amount">₹<%= walletBalance.toFixed(2) %></div>
          <div class="wallet-sub">Available balance</div>
        </div>
      </div>
      <% if (referralEarnings > 0) { %>
        <div style="margin-top:14px;padding:10px 14px;background:var(--tan-lite);border-radius:10px;font-size:13px;color:var(--brown);">
          🎉 <strong>₹<%= referralEarnings.toFixed(2) %></strong> earned from referrals
        </div>
      <% } %>
      <a href="/api/wallet" class="wallet-link">View wallet history →</a>
    </div>

    <!-- Stats -->
    <div class="card">
      <div class="card-title">📊 Your Stats</div>
      <div class="stat-row">
        <div class="stat-item">
          <div class="stat-number"><%= referredCount %></div>
          <div class="stat-label">Friends referred</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">₹<%= (referredCount * 100).toLocaleString('en-IN') %></div>
          <div class="stat-label">Total earned</div>
        </div>
      </div>
      <% if (referredCount === 0) { %>
        <div style="margin-top:16px;font-size:13px;color:var(--muted);">
          No referrals yet. Share your code to start earning!
        </div>
      <% } else { %>
        <div style="margin-top:16px;font-size:13px;color:var(--green);font-weight:600;">
          🌟 You've helped <%= referredCount %> friend<%= referredCount > 1 ? 's' : '' %> discover great fashion!
        </div>
      <% } %>
    </div>
  </div>

  <!-- ── Referral Code + Share ── -->
  <div class="grid-2" style="margin-bottom:20px;">

    <!-- Code -->
    <div class="card">
      <div class="card-title">🔑 Your Referral Code</div>
      <div class="code-display">
        <div class="code-text" id="refCode"><%= referralCode %></div>
        <button class="copy-btn" id="copyCodeBtn" onclick="copyCode()">Copy</button>
      </div>
      <div class="link-box">
        <div class="link-url" id="refUrl"><%= referralUrl %></div>
        <button class="copy-link-btn" onclick="copyLink()">Copy Link</button>
      </div>
      <div class="share-row">
        <a class="share-btn share-whatsapp"
           href="https://wa.me/?text=<%= encodeURIComponent('Hey! Shop kids fashion with me on Kids Fashion Store 👕👗 Use my referral code ' + referralCode + ' to get ₹50 wallet credit when you sign up! ' + referralUrl) %>"
           target="_blank">
          📱 WhatsApp
        </a>
        <button class="share-btn share-copy" onclick="copyAll()">
          📋 Copy Message
        </button>
      </div>
    </div>

    <!-- How it works -->
    <div class="card">
      <div class="card-title">⚡ How It Works</div>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-body">
            <div class="step-title">Share your code</div>
            <div class="step-desc">Send your unique referral code or link to friends and family.</div>
          </div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-body">
            <div class="step-title">Friend signs up</div>
            <div class="step-desc">They create an account using your referral code during signup.</div>
          </div>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div class="step-body">
            <div class="step-title">Both earn instantly</div>
            <div class="step-desc">You get <strong>₹100</strong> and your friend gets <strong>₹50</strong> in wallet credits right away.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Coupon Reward ── -->
  <% if (couponDetails) { %>
  <div class="card" style="margin-bottom:20px;">
    <div class="card-title">🎫 Your Referral Coupon Reward</div>
    <div class="coupon-card">
      <div class="coupon-code-badge"><%= couponDetails.name %></div>
      <div class="coupon-details">
        <strong>₹<%= couponDetails.offerPrice %> off</strong> on orders above ₹<%= couponDetails.minimumPrice %><br>
        Valid until: <strong><%= new Date(couponDetails.expireOn).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></strong><br>
        Use this coupon at checkout to redeem your reward.
      </div>
    </div>
  </div>
  <% } %>

</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2500);
  }

  function copyCode() {
    const code = document.getElementById('refCode').textContent.trim();
    navigator.clipboard.writeText(code).then(() => {
      const btn = document.getElementById('copyCodeBtn');
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      showToast('✅ Referral code copied!');
      setTimeout(() => {
        btn.textContent = 'Copy';
        btn.classList.remove('copied');
      }, 2000);
    });
  }

  function copyLink() {
    const url = document.getElementById('refUrl').textContent.trim();
    navigator.clipboard.writeText(url).then(() => showToast('✅ Referral link copied!'));
  }

  function copyAll() {
    const code = document.getElementById('refCode').textContent.trim();
    const url  = document.getElementById('refUrl').textContent.trim();
    const msg  = `Hey! Shop kids fashion with me 👕👗\nUse my referral code *${code}* to get ₹50 wallet credit when you sign up!\n${url}`;
    navigator.clipboard.writeText(msg).then(() => showToast('✅ Message copied! Paste and share.'));
  }
</script>

</body>
</html>
