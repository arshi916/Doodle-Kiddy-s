<!-- ══════════════════════════════════════════════════════════════════════════
     SCRIPTS
══════════════════════════════════════════════════════════════════════════════ -->
<script>
// ── SweetAlert helpers ────────────────────────────────────────────────────────
const swalBase = {
  background: '#ffffff',
  customClass: {
    popup:         'rounded-2xl shadow-2xl',
    title:         'text-gray-800 font-semibold',
    content:       'text-gray-600',
    confirmButton: 'rounded-xl px-6 py-3 font-medium',
    cancelButton:  'rounded-xl px-6 py-3 font-medium',
  },
};
const showLoading = (msg = 'Processing...') =>
  Swal.fire({ ...swalBase, title: msg, allowOutsideClick: false, allowEscapeKey: false, showConfirmButton: false, didOpen: () => Swal.showLoading() });
const showSuccess = (msg) =>
  Swal.fire({ ...swalBase, title: 'Success!', text: msg, icon: 'success', confirmButtonColor: '#059669', confirmButtonText: 'Great!' });
const showError = (msg) =>
  Swal.fire({ ...swalBase, title: 'Error!', text: msg, icon: 'error', confirmButtonColor: '#dc2626', confirmButtonText: 'OK' });

// ── Discount-type UI helpers ──────────────────────────────────────────────────
function applyTypeUI(prefix, type) {
  const isFlat = type === 'flat';
  const btnFlat = document.getElementById(`${prefix}_btn_flat`);
  const btnPct  = document.getElementById(`${prefix}_btn_pct`);

  btnFlat.className = `type-btn ${isFlat ? 'active-flat' : 'inactive'}`;
  btnPct.className  = `type-btn ${!isFlat ? 'active-pct'  : 'inactive'}`;

  document.getElementById(`${prefix}_discountType`).value = type;

  // Label & prefix symbol
  const label  = document.getElementById(`${prefix}_offerLabel`);
  const symbol = document.getElementById(`${prefix}_offerPrefix`);
  const input  = document.getElementById(`${prefix}_offerPrice`);

  if (isFlat) {
    label.innerHTML  = 'Discount Amount (₹) <span class="text-red-500">*</span>';
    symbol.textContent = '₹';
    input.placeholder  = '200';
    input.max          = '';
  } else {
    label.innerHTML  = 'Percentage (%) <span class="text-red-500">*</span>';
    symbol.textContent = '%';
    input.placeholder  = '10';
    input.max          = '99';
  }

  // Max discount cap row
  const capWrap = document.getElementById(`${prefix}_maxDiscountWrap`);
  capWrap.classList.toggle('hidden', isFlat);
}

function setAddType(type)  { applyTypeUI('add',  type); }
function setEditType(type) { applyTypeUI('edit', type); }

// ── Add Modal ─────────────────────────────────────────────────────────────────
function setMinDate(id) {
  const tomorrow = new Date(); tomorrow.setDate(tomorrow.getDate() + 1);
  document.getElementById(id).min = tomorrow.toISOString().split('T')[0];
}

function openAddModal() {
  document.getElementById('addCouponForm').reset();
  document.getElementById('add_islist').checked = true;
  setAddType('flat');
  setMinDate('add_expireOn');
  document.getElementById('addModal').classList.remove('hidden');
}
function closeAddModal() { document.getElementById('addModal').classList.add('hidden'); }

async function submitAddCoupon(e) {
  e.preventDefault();
  const name         = document.getElementById('add_name').value.trim();
  const discountType = document.getElementById('add_discountType').value;
  const offerPrice   = parseFloat(document.getElementById('add_offerPrice').value);
  const minimumPrice = parseFloat(document.getElementById('add_minimumPrice').value);
  const maxDiscount  = document.getElementById('add_maxDiscount').value
                         ? parseFloat(document.getElementById('add_maxDiscount').value) : null;
  const expireOn     = document.getElementById('add_expireOn').value;
  const islist       = document.getElementById('add_islist').checked;

  // Client-side guard
  if (discountType === 'flat' && offerPrice >= minimumPrice) {
    return showError('Discount amount must be less than the minimum order value.');
  }
  if (discountType === 'percentage' && (offerPrice <= 0 || offerPrice >= 100)) {
    return showError('Percentage must be between 1 and 99.');
  }

  closeAddModal();
  showLoading('Creating coupon...');
  try {
    const res  = await fetch('/admin/coupons/add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, discountType, offerPrice, maxDiscount, minimumPrice, expireOn, islist }),
    });
    const data = await res.json();
    if (data.success) { await showSuccess(data.message); window.location.reload(); }
    else throw new Error(data.message || 'Failed to create coupon');
  } catch (err) { showError(err.message); }
}

// ── Edit Modal ────────────────────────────────────────────────────────────────
function openEditModal(id, name, discountType, offerPrice, maxDiscount, minimumPrice, expireOn, islist) {
  document.getElementById('edit_id').value           = id;
  document.getElementById('edit_name').value         = name;
  document.getElementById('edit_minimumPrice').value = minimumPrice;
  document.getElementById('edit_expireOn').value     = expireOn;
  document.getElementById('edit_islist').checked     = islist;

  setEditType(discountType || 'flat');

  document.getElementById('edit_offerPrice').value = offerPrice;

  const capInput = document.getElementById('edit_maxDiscount');
  capInput.value = (maxDiscount !== null && maxDiscount !== undefined) ? maxDiscount : '';

  document.getElementById('editModal').classList.remove('hidden');
}
function closeEditModal() { document.getElementById('editModal').classList.add('hidden'); }

async function submitEditCoupon(e) {
  e.preventDefault();
  const id           = document.getElementById('edit_id').value;
  const name         = document.getElementById('edit_name').value.trim();
  const discountType = document.getElementById('edit_discountType').value;
  const offerPrice   = parseFloat(document.getElementById('edit_offerPrice').value);
  const minimumPrice = parseFloat(document.getElementById('edit_minimumPrice').value);
let maxValue = document.getElementById('edit_maxDiscount').value.trim();

const maxDiscount =
  maxValue && !isNaN(maxValue)
    ? parseFloat(maxValue)
    : null;
  const expireOn     = document.getElementById('edit_expireOn').value;
  const islist       = document.getElementById('edit_islist').checked;

  if (discountType === 'flat' && offerPrice >= minimumPrice) {
    return showError('Discount amount must be less than the minimum order value.');
  }
  if (discountType === 'percentage' && (offerPrice <= 0 || offerPrice >= 100)) {
    return showError('Percentage must be between 1 and 99.');
  }

  closeEditModal();
  showLoading('Saving changes...');
  try {
    const res  = await fetch(`/admin/coupons/edit/${id}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, discountType, offerPrice, maxDiscount, minimumPrice, expireOn, islist }),
    });
    const data = await res.json();
    if (data.success) { await showSuccess(data.message); window.location.reload(); }
    else throw new Error(data.message || 'Failed to update coupon');
  } catch (err) { showError(err.message); }
}

// ── Toggle ────────────────────────────────────────────────────────────────────
async function toggleCoupon(id, name, currentStatus) {
  const action = currentStatus ? 'deactivate' : 'activate';
  const result = await Swal.fire({
    ...swalBase,
    title: `${currentStatus ? 'Deactivate' : 'Activate'} Coupon?`,
    text: `Are you sure you want to ${action} "${name}"?`,
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: currentStatus ? '#dc2626' : '#16a34a',
    cancelButtonColor: '#6b7280',
    confirmButtonText: `Yes, ${action}!`,
    cancelButtonText: 'Cancel',
  });
  if (!result.isConfirmed) return;
  showLoading();
  try {
    const res  = await fetch('/admin/coupons/toggle', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ couponId: id }) });
    const data = await res.json();
    if (data.success) { await showSuccess(data.message); window.location.reload(); }
    else throw new Error(data.message);
  } catch (err) { showError(err.message); }
}

// ── Delete ────────────────────────────────────────────────────────────────────
async function deleteCoupon(id, name) {
  const result = await Swal.fire({
    ...swalBase, title: 'Delete Coupon?',
    text: `This will permanently delete "${name}". This action cannot be undone.`,
    icon: 'warning', showCancelButton: true,
    confirmButtonColor: '#dc2626', cancelButtonColor: '#6b7280',
    confirmButtonText: 'Yes, delete it!', cancelButtonText: 'Cancel',
  });
  if (!result.isConfirmed) return;
  showLoading('Deleting coupon...');
  try {
    const res  = await fetch('/admin/coupons/delete', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ couponId: id }) });
    const data = await res.json();
    if (data.success) { await showSuccess(data.message); window.location.reload(); }
    else throw new Error(data.message);
  } catch (err) { showError(err.message); }
}

// ── Overlay click to close ────────────────────────────────────────────────────
document.getElementById('addModal').addEventListener('click', function(e) { if (e.target === this) closeAddModal(); });
document.getElementById('editModal').addEventListener('click', function(e) { if (e.target === this) closeEditModal(); });

// ── Logout modal ──────────────────────────────────────────────────────────────
function showLogoutModal(e) { e.preventDefault(); document.getElementById('logout-modal').style.display = 'flex'; }
function closeLogoutModal() { document.getElementById('logout-modal').style.display = 'none'; }
document.getElementById('logout-modal').addEventListener('click', function(e) { if (e.target === this) closeLogoutModal(); });
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeLogoutModal(); });

// ── Server-side success flash ─────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function() {
  <% if (typeof successMessage !== 'undefined' && successMessage) { %>
    showSuccess('<%= successMessage %>');
  <% } %>
});
</script>
</body>
</html>
