<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Add Product</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .glass-effect { backdrop-filter: blur(10px); background: rgba(255,255,255,0.95); }
    .floating-label { position: relative; }
    .floating-label input:focus + label,
    .floating-label input:not(:placeholder-shown) + label,
    .floating-label select:focus + label,
    .floating-label textarea:focus + label,
    .floating-label textarea:not(:placeholder-shown) + label {
      transform: translateY(-24px) scale(0.85); color: #8B7355;
    }
    .floating-label label {
      position: absolute; left: 12px; top: 12px; background: white; padding: 0 4px;
      transition: all 0.2s ease; pointer-events: none; color: #6B7280;
    }
    .status-label {
      position: absolute; left: 12px; top: -9px; background: white; padding: 0 4px;
      font-size: 0.75rem; font-weight: 500; color: #8B7355; pointer-events: none; z-index: 1;
    }
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 3px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    .gradient-border { background: linear-gradient(135deg,#8B7355 0%,#A0845C 100%); padding: 2px; border-radius: 12px; }
    .gradient-border-inner { background: white; border-radius: 10px; padding: 1rem; }
  </style>
</head>
<body class="bg-gradient-to-br from-stone-100 to-amber-50 min-h-screen">

<div class="flex h-screen">

  <!-- ── Sidebar ── -->
  <aside class="w-64 bg-white shadow-2xl border-r border-stone-300 flex flex-col flex-shrink-0">
    <div class="p-6">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-gradient-to-r from-stone-600 to-amber-800 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
          </svg>
        </div>
        <h2 class="text-xl font-bold bg-gradient-to-r from-stone-600 to-amber-800 bg-clip-text text-transparent">AdminHub</h2>
      </div>
    </div>
    <nav class="mt-2 px-4 space-y-1 flex-1">
      <a href="/admin" class="flex items-center gap-3 py-3 px-4 text-gray-700 hover:bg-gradient-to-r hover:from-stone-100 hover:to-amber-50 hover:text-stone-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-stone-600 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M13 5v6h6"/></svg>
        <span class="font-medium">Dashboard</span>
      </a>
      <a href="/admin/customers" class="flex items-center gap-3 py-3 px-4 text-gray-700 hover:bg-gradient-to-r hover:from-stone-100 hover:to-amber-50 hover:text-stone-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-stone-600 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg>
        <span class="font-medium">Customers</span>
      </a>
      <a href="/admin/products" class="flex items-center gap-3 py-3 px-4 bg-gradient-to-r from-stone-200 to-amber-100 text-stone-800 rounded-xl shadow-sm">
        <svg class="w-5 h-5 text-stone-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V5a2 2 0 00-2-2H6a2 2 0 00-2 2v8m16 0H4m0 0v6a2 2 0 002 2h12a2 2 0 002-2v-6"/></svg>
        <span class="font-semibold">Products</span>
      </a>
      <a href="/admin/orders" class="flex items-center gap-3 py-3 px-4 text-gray-700 hover:bg-gradient-to-r hover:from-stone-100 hover:to-amber-50 hover:text-stone-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-stone-600 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        <span class="font-medium">Orders</span>
      </a>
      <a href="/admin/categories" class="flex items-center gap-3 py-3 px-4 text-gray-700 hover:bg-gradient-to-r hover:from-stone-100 hover:to-amber-50 hover:text-stone-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-stone-600 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        <span class="font-medium">Categories</span>
      </a>
      <a href="/admin/coupons" class="flex items-center gap-3 py-3 px-4 text-gray-700 hover:bg-gradient-to-r hover:from-stone-100 hover:to-amber-50 hover:text-stone-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-stone-600 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
        <span class="font-medium">Coupons</span>
      </a>
      <a href="#" class="flex items-center gap-3 py-3 px-4 text-gray-700 hover:bg-gradient-to-r hover:from-stone-100 hover:to-amber-50 hover:text-stone-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-stone-600 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span class="font-medium">Settings</span>
      </a>
    </nav>
    <div class="px-4 pb-4 border-t border-stone-200 pt-4">
      <a href="/admin/logout" class="flex items-center gap-3 py-3 px-4 text-red-600 hover:bg-red-50 hover:text-red-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-red-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a1 1 0 01-1 1H5a1 1 0 01-1-1V7a1 1 0 011-1h7a1 1 0 011 1v1"/></svg>
        <span class="font-medium">Logout</span>
      </a>
    </div>
  </aside>

  <!-- ── Main Content ── -->
  <div class="flex-1 flex flex-col overflow-hidden">

    <header class="glass-effect shadow-lg border-b border-stone-300 px-6 py-4 flex-shrink-0">
      <div class="flex items-center gap-4">
        <a href="/admin/products" class="inline-flex items-center text-stone-600 hover:text-stone-800 transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          Back to Products
        </a>
        <div class="h-6 w-px bg-stone-300"></div>
        <h1 class="text-2xl font-bold text-gray-800">Add New Product</h1>
      </div>
    </header>

    <main class="p-6 overflow-auto flex-1 custom-scrollbar">
      <div class="max-w-5xl mx-auto bg-white rounded-2xl shadow-xl border border-stone-300">

        <div class="bg-gradient-to-r from-stone-100 to-amber-50 rounded-t-2xl p-6 border-b border-stone-300">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-gradient-to-r from-stone-600 to-amber-800 rounded-2xl flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            </div>
            <div>
              <h2 class="text-xl font-bold text-gray-800">Product Information</h2>
              <p class="text-sm text-gray-600">Fill in all required fields to create the product</p>
            </div>
          </div>
        </div>

        <div class="p-8">
          <form id="productForm">

            <!-- ── Images ── -->
            <div class="mb-8">
              <div class="gradient-border">
                <div class="gradient-border-inner">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-8 h-8 bg-gradient-to-r from-stone-600 to-amber-800 rounded-lg flex items-center justify-center">
                      <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 002 2v12a2 2 0 002 2z"/></svg>
                    </div>
                    <div>
                      <h3 class="text-lg font-semibold text-gray-800">Product Images</h3>
                      <p class="text-sm text-gray-500">Upload 3–4 images (min 3, max 4 · max 5MB each)</p>
                    </div>
                  </div>

                  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-4">
                    <!-- Image Slot 0 -->
                    <div id="imageBox0" class="aspect-square border-2 border-dashed border-stone-300 flex items-center justify-center rounded-xl cursor-pointer bg-stone-50/50 hover:bg-stone-100/50 hover:border-stone-600 transition-all duration-300 relative group" onclick="triggerImageUpload(0)">
                      <span id="plusSign0" class="text-3xl text-stone-400 font-light group-hover:text-stone-600 transition-colors">+</span>
                      <img id="preview0" class="absolute inset-0 w-full h-full object-cover rounded-xl hidden" />
                      <button id="delete0" type="button" onclick="deleteImage(0,event)" class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-7 h-7 text-sm hover:bg-red-600 transition-all hover:scale-110 shadow-lg hidden z-10">×</button>
                    </div>
                    <!-- Image Slot 1 -->
                    <div id="imageBox1" class="aspect-square border-2 border-dashed border-stone-300 flex items-center justify-center rounded-xl cursor-pointer bg-stone-50/50 hover:bg-stone-100/50 hover:border-stone-600 transition-all duration-300 relative group" onclick="triggerImageUpload(1)">
                      <span id="plusSign1" class="text-3xl text-stone-400 font-light group-hover:text-stone-600 transition-colors">+</span>
                      <img id="preview1" class="absolute inset-0 w-full h-full object-cover rounded-xl hidden" />
                      <button id="delete1" type="button" onclick="deleteImage(1,event)" class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-7 h-7 text-sm hover:bg-red-600 transition-all hover:scale-110 shadow-lg hidden z-10">×</button>
                    </div>
                    <!-- Image Slot 2 -->
                    <div id="imageBox2" class="aspect-square border-2 border-dashed border-stone-300 flex items-center justify-center rounded-xl cursor-pointer bg-stone-50/50 hover:bg-stone-100/50 hover:border-stone-600 transition-all duration-300 relative group" onclick="triggerImageUpload(2)">
                      <span id="plusSign2" class="text-3xl text-stone-400 font-light group-hover:text-stone-600 transition-colors">+</span>
                      <img id="preview2" class="absolute inset-0 w-full h-full object-cover rounded-xl hidden" />
                      <button id="delete2" type="button" onclick="deleteImage(2,event)" class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-7 h-7 text-sm hover:bg-red-600 transition-all hover:scale-110 shadow-lg hidden z-10">×</button>
                    </div>
                    <!-- Image Slot 3 -->
                    <div id="imageBox3" class="aspect-square border-2 border-dashed border-stone-300 flex items-center justify-center rounded-xl cursor-pointer bg-stone-50/50 hover:bg-stone-100/50 hover:border-stone-600 transition-all duration-300 relative group" onclick="triggerImageUpload(3)">
                      <span id="plusSign3" class="text-3xl text-stone-400 font-light group-hover:text-stone-600 transition-colors">+</span>
                      <img id="preview3" class="absolute inset-0 w-full h-full object-cover rounded-xl hidden" />
                      <button id="delete3" type="button" onclick="deleteImage(3,event)" class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full w-7 h-7 text-sm hover:bg-red-600 transition-all hover:scale-110 shadow-lg hidden z-10">×</button>
                    </div>
                  </div>

                  <input type="file" id="imageInput0" accept="image/*" class="hidden" onchange="handleImageSelect(0)">
                  <input type="file" id="imageInput1" accept="image/*" class="hidden" onchange="handleImageSelect(1)">
                  <input type="file" id="imageInput2" accept="image/*" class="hidden" onchange="handleImageSelect(2)">
                  <input type="file" id="imageInput3" accept="image/*" class="hidden" onchange="handleImageSelect(3)">

                  <!-- imageError: starts hidden only — JS adds 'flex' when showing -->
                  <div id="imageError" class="text-red-500 text-sm mt-2 hidden items-center gap-2">
                    <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    <span id="imageErrorMsg"></span>
                  </div>
                  <div class="text-sm text-gray-600 mt-2">Images: <span id="currentCount" class="font-medium text-stone-600">0</span>/4</div>
                </div>
              </div>
            </div>

            <!-- ── Name & Category ── -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
              <div class="floating-label">
                <input id="productName" name="productName" required
                  class="w-full p-4 border-2 border-stone-200 rounded-xl focus:border-stone-600 focus:ring-4 focus:ring-stone-600/10 transition-all duration-300 bg-white" placeholder=" " />
                <label class="font-medium">Product Name <span class="text-red-500">*</span></label>
                <p id="productNameError" class="text-red-500 text-xs mt-1 hidden"></p>
              </div>
              <div class="floating-label">
                <select id="category" name="category" required
                  class="w-full p-4 border-2 border-stone-200 rounded-xl bg-white focus:border-stone-600 focus:ring-4 focus:ring-stone-600/10 transition-all duration-300">
                  <option value="" disabled selected>-- Select Category --</option>
                  <% if (categories && categories.length > 0) { %>
                    <% categories.forEach(cat => { %>
                      <option value="<%= cat._id %>"><%= cat.name %></option>
                    <% }) %>
                  <% } else { %>
                    <option disabled>No categories available</option>
                  <% } %>
                </select>
                <label class="font-medium">Category <span class="text-red-500">*</span></label>
                <p id="categoryError" class="text-red-500 text-xs mt-1 hidden"></p>
              </div>
            </div>

            <!-- ── Colors ── -->
            <div class="mb-8">
              <label class="block text-sm font-semibold text-gray-700 mb-3">Colors Available <span class="text-red-500">*</span></label>
              <div class="flex gap-3 flex-wrap" id="colorOptions">
                <button type="button" data-color="white"  class="color-btn flex items-center gap-2 px-4 py-2 border-2 border-stone-200 bg-stone-50 rounded-xl transition-all hover:border-stone-600"><span class="w-5 h-5 rounded-full bg-white border-2 border-gray-300 shadow-sm"></span><span class="font-medium">White</span></button>
                <button type="button" data-color="gray"   class="color-btn flex items-center gap-2 px-4 py-2 border-2 border-stone-200 bg-stone-50 rounded-xl transition-all hover:border-stone-600"><span class="w-5 h-5 rounded-full bg-gray-400 shadow-sm"></span><span class="font-medium">Gray</span></button>
                <button type="button" data-color="beige"  class="color-btn flex items-center gap-2 px-4 py-2 border-2 border-stone-200 bg-stone-50 rounded-xl transition-all hover:border-stone-600"><span class="w-5 h-5 rounded-full bg-yellow-100 shadow-sm"></span><span class="font-medium">Beige</span></button>
                <button type="button" data-color="yellow" class="color-btn flex items-center gap-2 px-4 py-2 border-2 border-stone-200 bg-stone-50 rounded-xl transition-all hover:border-stone-600"><span class="w-5 h-5 rounded-full bg-yellow-400 shadow-sm"></span><span class="font-medium">Yellow</span></button>
                <button type="button" data-color="orange" class="color-btn flex items-center gap-2 px-4 py-2 border-2 border-stone-200 bg-stone-50 rounded-xl transition-all hover:border-stone-600"><span class="w-5 h-5 rounded-full bg-orange-400 shadow-sm"></span><span class="font-medium">Orange</span></button>
                <button type="button" data-color="red"    class="color-btn flex items-center gap-2 px-4 py-2 border-2 border-stone-200 bg-stone-50 rounded-xl transition-all hover:border-stone-600"><span class="w-5 h-5 rounded-full bg-red-500 shadow-sm"></span><span class="font-medium">Red</span></button>
                <button type="button" data-color="purple" class="color-btn flex items-center gap-2 px-4 py-2 border-2 border-stone-200 bg-stone-50 rounded-xl transition-all hover:border-stone-600"><span class="w-5 h-5 rounded-full bg-purple-500 shadow-sm"></span><span class="font-medium">Purple</span></button>
                <button type="button" data-color="blue"   class="color-btn flex items-center gap-2 px-4 py-2 border-2 border-stone-200 bg-stone-50 rounded-xl transition-all hover:border-stone-600"><span class="w-5 h-5 rounded-full bg-blue-500 shadow-sm"></span><span class="font-medium">Blue</span></button>
                <button type="button" data-color="green"  class="color-btn flex items-center gap-2 px-4 py-2 border-2 border-stone-200 bg-stone-50 rounded-xl transition-all hover:border-stone-600"><span class="w-5 h-5 rounded-full bg-green-500 shadow-sm"></span><span class="font-medium">Green</span></button>
                <button type="button" data-color="black"  class="color-btn flex items-center gap-2 px-4 py-2 border-2 border-stone-200 bg-stone-50 rounded-xl transition-all hover:border-stone-600"><span class="w-5 h-5 rounded-full bg-black shadow-sm"></span><span class="font-medium">Black</span></button>
              </div>
              <p id="colorError" class="text-red-500 text-xs mt-2 hidden"></p>
            </div>

            <!-- ── Stock Table (dynamic, same as edit-product) ── -->
            <div id="colorSizeStockSection" class="mb-8"></div>

            <!-- ── Pricing & Status ── -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
              <div class="floating-label">
                <input id="regularPrice" name="regularPrice" type="number" min="1" step="0.01"
                  class="w-full p-4 border-2 border-stone-200 rounded-xl focus:border-stone-600 focus:ring-4 focus:ring-stone-600/10 transition-all duration-300 bg-white" placeholder=" " />
                <label class="font-medium">Regular Price (₹) <span class="text-red-500">*</span></label>
                <p id="regularPriceError" class="text-red-500 text-xs mt-1 hidden"></p>
              </div>
              <div class="floating-label">
                <input id="salePrice" name="salePrice" type="number" min="1" step="0.01"
                  class="w-full p-4 border-2 border-stone-200 rounded-xl focus:border-stone-600 focus:ring-4 focus:ring-stone-600/10 transition-all duration-300 bg-white" placeholder=" " />
                <label class="font-medium">Sale Price (₹) <span class="text-red-500">*</span></label>
                <p id="salePriceError" class="text-red-500 text-xs mt-1 hidden"></p>
              </div>
              <div class="floating-label">
                <input id="quantity" type="number" readonly value="0"
                  class="w-full p-4 border-2 border-stone-200 rounded-xl bg-stone-50 cursor-not-allowed" placeholder=" " />
                <label class="font-medium">Total Quantity (Auto)</label>
              </div>
              <!-- Status badge — exactly matching edit-product -->
              <div class="relative">
                <span class="status-label">Status (Auto)</span>
                <div id="statusBadge" class="w-full px-4 border-2 rounded-xl flex items-center gap-3 h-[58px] transition-all duration-300 border-gray-200 bg-gray-50">
                  <div id="statusDot" class="w-3 h-3 rounded-full flex-shrink-0 bg-gray-400"></div>
                  <span id="statusText" class="font-semibold text-sm text-gray-500">Set stock first</span>
                </div>
              </div>
            </div>

            <!-- ── Return Policy ── -->
            <div class="mb-8">
              <label class="block text-sm font-semibold text-gray-700 mb-4">Return Policy</label>
              <div class="flex gap-6">
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input type="radio" name="returnPolicy" value="false" checked class="w-4 h-4 text-stone-600 focus:ring-stone-500" />
                  <span class="flex items-center gap-2 font-medium text-gray-700 group-hover:text-stone-600 transition-colors">
                    <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    No Returns
                  </span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer group">
                  <input type="radio" name="returnPolicy" value="true" class="w-4 h-4 text-stone-600 focus:ring-stone-500" />
                  <span class="flex items-center gap-2 font-medium text-gray-700 group-hover:text-stone-600 transition-colors">
                    <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Returns Allowed
                  </span>
                </label>
              </div>
            </div>

            <!-- ── Description ── -->
            <div class="mb-8">
              <div class="floating-label">
                <textarea id="description" name="description" required
                  class="w-full p-4 border-2 border-stone-200 rounded-xl focus:border-stone-600 focus:ring-4 focus:ring-stone-600/10 transition-all duration-300 h-32 resize-none bg-white" placeholder=" "></textarea>
                <label class="font-medium">Description <span class="text-red-500">*</span></label>
                <p id="descriptionError" class="text-red-500 text-xs mt-1 hidden"></p>
              </div>
            </div>

            <input type="hidden" name="sizes" id="sizesInput" value="XS,S,M,L,XL">

            <!-- ── Buttons ── -->
            <div class="flex justify-end gap-4">
              <a href="/admin/products" class="px-6 py-3 bg-stone-200 text-stone-700 font-semibold rounded-xl hover:bg-stone-300 transition-all duration-300">Cancel</a>
              <button type="submit" id="submitBtn"
                class="px-8 py-3 bg-gradient-to-r from-stone-600 to-amber-800 text-white font-semibold rounded-xl hover:from-stone-700 hover:to-amber-900 transition-all duration-300 transform hover:scale-105 hover:shadow-xl">
                <span id="submitBtnText" class="flex items-center gap-3">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
                  Add Product
                </span>
              </button>
            </div>

          </form>
        </div>
      </div>
    </main>
  </div>
</div>

<!-- ── Crop Modal ──
     KEY FIX: only 'hidden' in HTML. JS toggles 'flex' separately.
     Having both 'hidden' AND 'flex' in HTML means it never shows. -->
<div id="cropModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
  <div class="bg-white rounded-3xl shadow-2xl max-w-3xl w-full mx-4 overflow-hidden">
    <div class="bg-gradient-to-r from-stone-600 to-amber-800 p-6">
      <h3 class="text-xl font-bold text-white">Crop Image</h3>
    </div>
    <div class="p-6">
      <div class="mb-6 bg-stone-50 rounded-2xl p-4">
        <img id="cropImage" style="max-width:100%; height:400px; display:block; margin:0 auto;">
      </div>
      <div class="flex justify-end gap-4">
        <button type="button" id="cancelCrop" class="px-6 py-3 bg-stone-100 text-stone-700 font-medium rounded-xl hover:bg-stone-200">Cancel</button>
        <button type="button" id="confirmCrop" class="px-6 py-3 bg-gradient-to-r from-stone-600 to-amber-800 text-white font-medium rounded-xl hover:from-stone-700 hover:to-amber-900">Crop & Save</button>
      </div>
    </div>
  </div>
</div>

<script>
/* ─── State ─────────────────────────────────────────── */
let cropper           = null;
let currentImageIndex = 0;
let uploadedFiles     = [null, null, null, null];
let selectedColors    = [];
let isSubmitting      = false;
const SIZES           = ["XS", "S", "M", "L", "XL"];

/* ─── Modal open/close (same logic as edit-product) ─── */
function openModal() {
  const m = document.getElementById('cropModal');
  m.classList.remove('hidden');
  m.classList.add('flex');
}
function closeModal() {
  const m = document.getElementById('cropModal');
  m.classList.add('hidden');
  m.classList.remove('flex');
}

/* ─── Image count ───────────────────────────────────── */
function updateImageCount() {
  document.getElementById('currentCount').textContent =
    uploadedFiles.filter(f => f !== null).length;
}

/* ─── Status badge (identical to edit-product) ──────── */
function updateStatusBadge(total) {
  const badge = document.getElementById('statusBadge');
  const dot   = document.getElementById('statusDot');
  const text  = document.getElementById('statusText');
  if (total > 0) {
    badge.className = 'w-full px-4 border-2 rounded-xl flex items-center gap-3 h-[58px] transition-all duration-300 border-green-200 bg-green-50';
    dot.className   = 'w-3 h-3 rounded-full flex-shrink-0 bg-green-500';
    text.textContent = 'Available';
    text.className  = 'font-semibold text-sm text-green-700';
  } else if (document.querySelectorAll('.stock-input').length > 0) {
    badge.className = 'w-full px-4 border-2 rounded-xl flex items-center gap-3 h-[58px] transition-all duration-300 border-red-200 bg-red-50';
    dot.className   = 'w-3 h-3 rounded-full flex-shrink-0 bg-red-500';
    text.textContent = 'Out of Stock';
    text.className  = 'font-semibold text-sm text-red-700';
  } else {
    badge.className = 'w-full px-4 border-2 rounded-xl flex items-center gap-3 h-[58px] transition-all duration-300 border-gray-200 bg-gray-50';
    dot.className   = 'w-3 h-3 rounded-full flex-shrink-0 bg-gray-400';
    text.textContent = 'Set stock first';
    text.className  = 'font-semibold text-sm text-gray-500';
  }
}

/* ─── Stock table (identical pattern to edit-product) ── */
function renderColorSizeStock() {
  const container = document.getElementById('colorSizeStockSection');
  container.innerHTML = '';

  if (selectedColors.length === 0) {
    container.innerHTML = '<p class="text-sm text-gray-500 italic">Select at least one color to manage sizes and stock.</p>';
    updateStatusBadge(0);
    document.getElementById('quantity').value = 0;
    return;
  }

  let tableHTML = `
    <div class="mt-2 overflow-x-auto rounded-xl border border-stone-300">
      <table class="min-w-full bg-white">
        <thead class="bg-stone-100">
          <tr>
            <th class="px-6 py-4 text-left font-semibold text-gray-700">Color</th>
            ${SIZES.map(s => `<th class="px-6 py-4 text-center font-semibold text-gray-700">${s}</th>`).join('')}
            <th class="px-6 py-4 text-center font-semibold text-gray-700">Row Total</th>
          </tr>
        </thead>
        <tbody>
  `;

  selectedColors.forEach(color => {
    tableHTML += `
      <tr class="border-t border-stone-200">
        <td class="px-6 py-4">
          <div class="flex items-center gap-3">
            <div class="w-6 h-6 rounded-full ${color === 'white' ? 'bg-white border-2 border-gray-300' : color === 'beige' ? 'bg-yellow-100' : 'bg-' + color + '-400'}"></div>
            <span class="font-medium capitalize">${color}</span>
          </div>
        </td>`;
    SIZES.forEach(size => {
      tableHTML += `
        <td class="px-6 py-4 text-center">
          <input type="number" name="stock_${color}_${size}" min="0" value="0"
            class="w-24 px-3 py-2 border border-stone-300 rounded-lg focus:outline-none focus:border-stone-600 text-center stock-input">
        </td>`;
    });
    tableHTML += `
        <td id="rowTotal_${color}" class="px-6 py-4 text-center font-bold text-stone-700">0</td>
      </tr>`;
  });

  tableHTML += `</tbody></table></div>`;
  container.innerHTML = tableHTML;

  function recalcAll() {
    let grand = 0;
    selectedColors.forEach(color => {
      let rowTotal = 0;
      SIZES.forEach(size => {
        const inp = container.querySelector(`input[name="stock_${color}_${size}"]`);
        rowTotal += parseInt(inp?.value || 0) || 0;
      });
      const cell = document.getElementById(`rowTotal_${color}`);
      if (cell) cell.textContent = rowTotal;
      grand += rowTotal;
    });
    document.getElementById('quantity').value = grand;
    updateStatusBadge(grand);
  }

  container.querySelectorAll('.stock-input').forEach(inp => inp.addEventListener('input', recalcAll));
  recalcAll();
}

/* ─── Color buttons (identical to edit-product) ─────── */
document.querySelectorAll('.color-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    const color = this.dataset.color;
    const idx   = selectedColors.indexOf(color);
    if (idx === -1) selectedColors.push(color);
    else selectedColors.splice(idx, 1);

    const active = selectedColors.includes(color);
    this.classList.toggle('border-stone-600', active);
    this.classList.toggle('bg-stone-100',     active);
    this.classList.toggle('border-stone-200', !active);
    this.classList.toggle('bg-stone-50',      !active);

    hideError('colorError');
    renderColorSizeStock();
  });
});

/* ─── Image upload (identical to edit-product) ──────── */
function triggerImageUpload(index) {
  document.getElementById(`imageInput${index}`).click();
}

function handleImageSelect(index) {
  const input = document.getElementById(`imageInput${index}`);
  const file  = input.files[0];
  if (!file) return;
  if (!file.type.startsWith('image/')) { showError('imageError', 'Please select a valid image file.'); return; }
  if (file.size > 5 * 1024 * 1024)    { showError('imageError', 'Image must be less than 5MB.'); return; }

  currentImageIndex = index;
  const reader = new FileReader();
  reader.onload = e => {
    document.getElementById('cropImage').src = e.target.result;
    openModal();
    if (cropper) cropper.destroy();
    cropper = new Cropper(document.getElementById('cropImage'), {
      aspectRatio: 1, viewMode: 1, dragMode: 'move', autoCropArea: 1
    });
  };
  reader.readAsDataURL(file);
}

function deleteImage(index, event) {
  event.stopPropagation();
  uploadedFiles[index] = null;
  document.getElementById(`imageInput${index}`).value = '';
  document.getElementById(`preview${index}`).classList.add('hidden');
  document.getElementById(`preview${index}`).src = '';
  document.getElementById(`plusSign${index}`).classList.remove('hidden');
  document.getElementById(`delete${index}`).classList.add('hidden');
  updateImageCount();
  hideError('imageError');
}

/* ─── Crop confirm/cancel (identical to edit-product) ── */
document.getElementById('cancelCrop').onclick = () => {
  closeModal();
  if (cropper) { cropper.destroy(); cropper = null; }
  document.getElementById(`imageInput${currentImageIndex}`).value = '';
};

document.getElementById('confirmCrop').onclick = () => {
  if (!cropper) return;
  const canvas = cropper.getCroppedCanvas({ width: 300, height: 300 });
  canvas.toBlob(blob => {
    const file = new File([blob], `product-${currentImageIndex}-${Date.now()}.jpg`, { type: 'image/jpeg' });
    uploadedFiles[currentImageIndex] = file;

    const preview = document.getElementById(`preview${currentImageIndex}`);
    preview.src = URL.createObjectURL(file);
    preview.classList.remove('hidden');
    document.getElementById(`plusSign${currentImageIndex}`).classList.add('hidden');
    document.getElementById(`delete${currentImageIndex}`).classList.remove('hidden');

    closeModal();
    if (cropper) { cropper.destroy(); cropper = null; }
    updateImageCount();
    hideError('imageError');
  }, 'image/jpeg', 0.9);
};

/* ─── Error helpers ─────────────────────────────────── */
function showError(id, msg) {
  if (id === 'imageError') {
    document.getElementById('imageErrorMsg').textContent = msg;
    const el = document.getElementById('imageError');
    el.classList.remove('hidden');
    el.classList.add('flex');
  } else {
    const el = document.getElementById(id);
    if (el) { el.textContent = msg; el.classList.remove('hidden'); }
  }
}
function hideError(id) {
  const el = document.getElementById(id);
  if (!el) return;
  el.classList.add('hidden');
  if (id === 'imageError') el.classList.remove('flex');
}

/* ─── Form submit ───────────────────────────────────── */
document.getElementById('productForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  if (isSubmitting) return;

  let valid = true;

  const imgCount = uploadedFiles.filter(f => f !== null).length;
  if (imgCount < 3)      { showError('imageError', `Upload at least 3 images (currently ${imgCount}).`); valid = false; }
  else if (imgCount > 4) { showError('imageError', 'Maximum 4 images allowed.'); valid = false; }
  else hideError('imageError');

  const name = document.getElementById('productName').value.trim();
  if (!name || name.length < 3)  { showError('productNameError', 'Product name must be at least 3 characters.'); valid = false; }
  else if (name.length > 50)     { showError('productNameError', 'Product name cannot exceed 50 characters.'); valid = false; }
  else hideError('productNameError');

  const cat = document.getElementById('category').value;
  if (!cat) { showError('categoryError', 'Please select a category.'); valid = false; }
  else hideError('categoryError');

  if (selectedColors.length === 0) { showError('colorError', 'Please select at least one color.'); valid = false; }
  else hideError('colorError');

  const regPrice = parseFloat(document.getElementById('regularPrice').value);
  const salPrc   = parseFloat(document.getElementById('salePrice').value);
  if (!regPrice || regPrice <= 0)     { showError('regularPriceError', 'Enter a valid regular price.'); valid = false; }
  else hideError('regularPriceError');
  if (!salPrc || salPrc <= 0)         { showError('salePriceError', 'Enter a valid sale price.'); valid = false; }
  else if (salPrc >= regPrice)        { showError('salePriceError', 'Sale price must be less than regular price.'); valid = false; }
  else hideError('salePriceError');

  const qty = parseInt(document.getElementById('quantity').value) || 0;
  if (qty <= 0) { showError('colorError', 'Total stock must be greater than 0. Enter quantities in the table above.'); valid = false; }

  const desc = document.getElementById('description').value.trim();
  if (!desc || desc.length < 10)  { showError('descriptionError', 'Description must be at least 10 characters.'); valid = false; }
  else if (desc.length > 1000)    { showError('descriptionError', 'Description cannot exceed 1000 characters.'); valid = false; }
  else hideError('descriptionError');

  if (!valid) return;

  isSubmitting = true;
  const btn     = document.getElementById('submitBtn');
  const btnText = document.getElementById('submitBtnText');
  btn.disabled  = true;
  btnText.innerHTML = `
    <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
    Saving...`;

  const formData = new FormData();
  formData.append('productName',  name);
  formData.append('description',  desc);
  formData.append('category',     cat);
  formData.append('regularPrice', document.getElementById('regularPrice').value);
  formData.append('salePrice',    document.getElementById('salePrice').value);
  formData.append('returnPolicy', document.querySelector('[name="returnPolicy"]:checked').value);
  formData.append('sizes', 'XS,S,M,L,XL');

  selectedColors.forEach(c => formData.append('color', c));

  document.querySelectorAll('#colorSizeStockSection input[name^="stock_"]').forEach(el => {
    formData.append(el.name, el.value || '0');
  });

  uploadedFiles.forEach(f => { if (f) formData.append('productImage', f); });

  try {
    const response = await fetch('/admin/products/add', {
      method:  'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest' },
      body:    formData
    });
    const result = await response.json();

    if (result.success) {
      Swal.fire({
        icon: 'success', title: 'Product Added!',
        text: result.message || 'Product created successfully.',
        confirmButtonColor: '#8B7355',
        timer: 3000, timerProgressBar: true, allowOutsideClick: false
      }).then(() => { window.location.href = '/admin/products'; });
    } else {
      Swal.fire({
        icon: 'error', title: 'Failed',
        text: result.message || 'Something went wrong.',
        confirmButtonColor: '#dc2626'
      });
    }
  } catch (err) {
    console.error('Submit error:', err);
    Swal.fire({
      icon: 'error', title: 'Network Error',
      text: 'Could not reach the server. Please check your connection.',
      confirmButtonColor: '#dc2626'
    });
  } finally {
    btn.disabled = false;
    btnText.innerHTML = `
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
      </svg>
      Add Product`;
    isSubmitting = false;
  }
});

/* ─── Init ──────────────────────────────────────────── */
updateImageCount();
renderColorSizeStock();
</script>
</body>
</html>
