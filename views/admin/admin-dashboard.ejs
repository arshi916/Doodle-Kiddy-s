<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
    .glass-effect {
      backdrop-filter: blur(10px);
      background: rgba(255, 255, 255, 0.95);
    }
    .hover-lift {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-lift:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(101, 67, 33, 0.15);
    }
    .fade-in {
      animation: fadeIn 0.5s ease-in;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 500;
    }
    .filter-tab {
      padding: 4px 12px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
      background: #e7e5e4;
      color: #78716c;
      border: none;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.15s;
    }
    .filter-tab.active {
      background: linear-gradient(135deg, #57534e, #92400e);
      color: white;
    }
    .tab-btn {
      padding: 12px 20px;
      font-size: 13px;
      font-weight: 600;
      border: none;
      background: none;
      cursor: pointer;
      color: #a8a29e;
      border-bottom: 2px solid transparent;
      font-family: inherit;
      transition: all 0.15s;
    }
    .tab-btn.active {
      color: #1c1917;
      border-bottom-color: #92400e;
    }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
    .prog-bar { height: 4px; border-radius: 99px; background: #e8e0d4; overflow: hidden; }
    .prog-fill { height: 100%; border-radius: 99px; background: linear-gradient(90deg, #92400e, #d97706); }
    .rank-badge {
      width: 24px; height: 24px; border-radius: 5px;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 700; color: white;
    }
    #ledger-tbody tr td:nth-child(4) { color: #16a34a; font-weight: 600; }
    #ledger-tbody tr td:nth-child(5) { color: #dc2626; font-weight: 600; }
    #ledger-tbody tr.total-row td { background: #f5ede2; font-weight: 700; }
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #d6cfc7; border-radius: 99px; }
  </style>
</head>
<body class="bg-gradient-to-br from-stone-100 to-amber-50 min-h-screen">

<div class="flex h-screen">

  <!-- ─── Sidebar ─── -->
  <aside class="w-64 bg-white shadow-2xl border-r border-stone-300">
    <div class="p-6">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-gradient-to-r from-stone-600 to-amber-800 rounded-lg flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
          </svg>
        </div>
        <h2 class="text-xl font-bold bg-gradient-to-r from-stone-600 to-amber-800 bg-clip-text text-transparent">AdminHub</h2>
      </div>
    </div>

    <nav class="mt-2 px-4 space-y-1">

      <!-- Dashboard — Active -->
      <a href="/admin" class="flex items-center gap-3 py-3 px-4 bg-gradient-to-r from-stone-200 to-amber-100 text-stone-800 rounded-xl shadow-sm">
        <svg class="w-5 h-5 text-stone-700" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M13 5v6h6" />
        </svg>
        <span class="font-semibold">Dashboard</span>
      </a>

      <a href="/admin/customers" class="flex items-center gap-3 py-3 px-4 text-gray-700 hover:bg-gradient-to-r hover:from-stone-100 hover:to-amber-50 hover:text-stone-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-stone-600 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
        </svg>
        <span class="font-medium">Customers</span>
      </a>

      <a href="/admin/products" class="flex items-center gap-3 py-3 px-4 text-gray-700 hover:bg-gradient-to-r hover:from-stone-100 hover:to-amber-50 hover:text-stone-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-stone-600 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V5a2 2 0 00-2-2H6a2 2 0 00-2 2v8m16 0H4m0 0v6a2 2 0 002 2h12a2 2 0 002-2v-6" />
        </svg>
        <span class="font-medium">Products</span>
      </a>

      <a href="/admin/orders" class="flex items-center gap-3 py-3 px-4 text-gray-700 hover:bg-gradient-to-r hover:from-stone-100 hover:to-amber-50 hover:text-stone-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-stone-600 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        <span class="font-medium">Orders</span>
      </a>

      <a href="/admin/categories" class="flex items-center gap-3 py-3 px-4 text-gray-700 hover:bg-gradient-to-r hover:from-stone-100 hover:to-amber-50 hover:text-stone-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-stone-600 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
        </svg>
        <span class="font-medium">Categories</span>
      </a>

      <a href="/admin/sales-report" class="flex items-center gap-3 py-3 px-4 text-gray-700 hover:bg-gradient-to-r hover:from-stone-100 hover:to-amber-50 hover:text-stone-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-stone-600 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <span class="font-medium">Sales Report</span>
      </a>

      <a href="/admin/coupons" class="flex items-center gap-3 py-3 px-4 text-gray-700 hover:bg-gradient-to-r hover:from-stone-100 hover:to-amber-50 hover:text-stone-700 rounded-xl transition-all duration-200 group">
        <svg class="w-5 h-5 text-stone-600 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
        </svg>
        <span class="font-medium">Coupons</span>
      </a>

      <div class="pt-4 mt-4 border-t border-stone-200">
        <a href="#" onclick="showLogoutModal(event)" class="flex items-center gap-3 py-3 px-4 text-red-600 hover:bg-red-50 hover:text-red-700 rounded-xl transition-all duration-200 group">
          <svg class="w-5 h-5 text-red-500 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a1 1 0 01-1 1H5a1 1 0 01-1-1V7a1 1 0 011-1h7a1 1 0 011 1v1" />
          </svg>
          <span class="font-medium">Logout</span>
        </a>
      </div>
    </nav>
  </aside>

  <!-- ─── Main Content ─── -->
  <div class="flex-1 flex flex-col overflow-hidden">

    <!-- Header -->
    <header class="glass-effect shadow-lg border-b border-stone-300 px-6 py-4">
      <div class="flex justify-between items-center">
        <div class="flex items-center gap-4">
          <h1 class="text-2xl font-bold text-gray-800">Dashboard</h1>
          <div class="status-badge bg-stone-200 text-stone-800">
            <div class="w-2 h-2 bg-stone-600 rounded-full animate-pulse"></div>
            Overview
          </div>
        </div>
        <div class="relative">
          <input type="text" id="search-input" placeholder="Search..."
                 class="pl-10 pr-4 py-2 w-56 border border-stone-400 rounded-xl focus:ring-2 focus:ring-stone-500 focus:border-transparent transition-all duration-200 shadow-sm text-sm"/>
          <svg class="absolute left-3 top-2.5 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>
    </header>

    <!-- Page Body -->
    <main class="p-6 overflow-auto flex-1">

      <!-- ── Stat Cards ── -->
      <div class="grid grid-cols-4 gap-4 mb-6">

        <div class="bg-white rounded-2xl shadow-xl border border-stone-300 hover-lift fade-in p-5">
          <div class="flex justify-between items-start">
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Total Users</p>
              <p class="text-3xl font-bold text-gray-800 mt-1 leading-none"><%= totalUsers || 0 %></p>
              <p class="text-xs text-green-600 mt-2">Active customers</p>
            </div>
            <div class="w-11 h-11 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl border border-stone-300 hover-lift fade-in p-5" style="animation-delay:0.05s">
          <div class="flex justify-between items-start">
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Products</p>
              <p class="text-3xl font-bold text-gray-800 mt-1 leading-none"><%= totalProducts || 0 %></p>
              <p class="text-xs text-purple-600 mt-2">In catalog</p>
            </div>
            <div class="w-11 h-11 rounded-xl bg-purple-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V5a2 2 0 00-2-2H6a2 2 0 00-2 2v8m16 0H4m0 0v6a2 2 0 002 2h12a2 2 0 002-2v-6"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl border border-stone-300 hover-lift fade-in p-5" style="animation-delay:0.1s">
          <div class="flex justify-between items-start">
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Orders</p>
              <p class="text-3xl font-bold text-gray-800 mt-1 leading-none"><%= totalOrders || 0 %></p>
              <p class="text-xs text-orange-600 mt-2">All time</p>
            </div>
            <div class="w-11 h-11 rounded-xl bg-orange-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
              </svg>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl border border-stone-300 hover-lift fade-in p-5" style="animation-delay:0.15s">
          <div class="flex justify-between items-start">
            <div>
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Revenue</p>
              <p class="text-3xl font-bold text-gray-800 mt-1 leading-none">₹<%= (totalRevenue || 0).toLocaleString('en-IN') %></p>
              <p class="text-xs text-green-600 mt-2">Net earnings</p>
            </div>
            <div class="w-11 h-11 rounded-xl bg-green-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1"/>
              </svg>
            </div>
          </div>
        </div>

      </div>

      <!-- ── Charts Row ── -->
      <div class="grid grid-cols-3 gap-4 mb-6">

        <!-- Sales Chart -->
        <div class="col-span-2 bg-white rounded-2xl shadow-xl border border-stone-300 hover-lift fade-in overflow-hidden">
          <div class="p-4 border-b border-stone-300 bg-gradient-to-r from-stone-100 to-amber-50 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="bg-gradient-to-r from-stone-600 to-amber-800 p-2 rounded-lg">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
              </div>
              <span class="text-sm font-bold text-gray-800">Sales Overview</span>
            </div>
            <div class="flex gap-1" id="chart-filter-tabs">
              <button class="filter-tab active" onclick="loadChart('weekly',this)">Weekly</button>
              <button class="filter-tab" onclick="loadChart('monthly',this)">Monthly</button>
              <button class="filter-tab" onclick="loadChart('yearly',this)">Yearly</button>
            </div>
          </div>
          <div class="p-4">
            <canvas id="salesChart" height="115"></canvas>
          </div>
        </div>

        <!-- Top Categories -->
        <div class="bg-white rounded-2xl shadow-xl border border-stone-300 hover-lift fade-in overflow-hidden">
          <div class="p-4 border-b border-stone-300 bg-gradient-to-r from-stone-100 to-amber-50 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="bg-gradient-to-r from-stone-600 to-amber-800 p-2 rounded-lg">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
                </svg>
              </div>
              <span class="text-sm font-bold text-gray-800">Top Categories</span>
            </div>
            <span class="text-xs text-gray-400 font-medium">Top 5</span>
          </div>
          <div class="p-4" id="category-legend"></div>
        </div>

      </div>

      <!-- ── Best Selling / Ledger Tabs ── -->
      <div class="bg-white rounded-2xl shadow-xl border border-stone-300 hover-lift fade-in overflow-hidden">

        <!-- Tab Nav -->
        <div class="flex border-b border-stone-300 bg-gradient-to-r from-stone-100 to-amber-50">
          <button class="tab-btn active" id="tab-btn-products" onclick="switchTab('products')">🏆 Best Selling Products</button>
          <button class="tab-btn" id="tab-btn-categories" onclick="switchTab('categories')">📦 Best Categories</button>
          <button class="tab-btn" id="tab-btn-ledger" onclick="switchTab('ledger')">📒 Ledger Book</button>
        </div>

        <!-- Tab: Best Products -->
        <div id="tab-products" class="tab-content active overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gradient-to-r from-stone-100 to-amber-50 border-b border-stone-300">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider w-12">#</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Product</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Category</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Units Sold</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Revenue</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider w-28">Share</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-stone-200" id="best-products-tbody">
              <tr><td colspan="6" class="text-center py-8 text-gray-400 text-sm">Loading...</td></tr>
            </tbody>
          </table>
        </div>

        <!-- Tab: Best Categories -->
        <div id="tab-categories" class="tab-content overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gradient-to-r from-stone-100 to-amber-50 border-b border-stone-300">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider w-12">#</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Category</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Products Listed</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Units Sold</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Revenue</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider w-28">Share</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-stone-200" id="best-categories-tbody">
              <tr><td colspan="6" class="text-center py-8 text-gray-400 text-sm">Loading...</td></tr>
            </tbody>
          </table>
        </div>

        <!-- Tab: Ledger Book -->
        <div id="tab-ledger" class="tab-content">
          <!-- Ledger Controls -->
          <div class="px-5 py-3 border-b border-stone-300 bg-gradient-to-r from-stone-100 to-amber-50 flex items-center justify-between flex-wrap gap-3">
            <div class="flex items-center gap-3">
              <div class="flex gap-1" id="ledger-filter-tabs">
                <button class="filter-tab active" onclick="loadLedger('monthly',this)">Monthly</button>
                <button class="filter-tab" onclick="loadLedger('quarterly',this)">Quarterly</button>
                <button class="filter-tab" onclick="loadLedger('yearly',this)">Yearly</button>
              </div>
              <select id="ledger-year" onchange="loadCurrentLedger()"
                      class="px-3 py-1.5 border border-stone-400 rounded-lg text-xs bg-white text-stone-700 font-medium focus:ring-2 focus:ring-stone-500 focus:border-transparent">
              </select>
            </div>
            <div class="flex gap-2">
              <button onclick="exportLedgerExcel()"
                      class="inline-flex items-center gap-1.5 px-4 py-2 bg-green-600 text-white text-xs font-semibold rounded-xl hover:bg-green-700 transition-colors shadow-sm">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Export Excel
              </button>
              <button onclick="printLedger()"
                      class="inline-flex items-center gap-1.5 px-4 py-2 bg-gradient-to-r from-stone-600 to-stone-700 text-white text-xs font-semibold rounded-xl hover:from-stone-700 hover:to-stone-800 transition-all shadow-sm">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
                </svg>
                Print
              </button>
            </div>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm" id="ledger-table">
              <thead class="bg-gradient-to-r from-stone-100 to-amber-50 border-b border-stone-300">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Period</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Orders</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Gross Revenue</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Credits (+)</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Debits (−)</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Net Balance</th>
                  <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Running Total</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-stone-200" id="ledger-tbody">
                <tr><td colspan="7" class="text-center py-8 text-gray-400 text-sm">Loading ledger...</td></tr>
              </tbody>
            </table>
          </div>
        </div>

      </div><!-- end tab card -->

    </main>
  </div>
</div>

<!-- ── Logout Modal ── -->
<div id="logout-modal" style="display:none;" class="fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50">
  <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-sm mx-4 text-center">
    <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
      <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a1 1 0 01-1 1H5a1 1 0 01-1-1V7a1 1 0 011-1h7a1 1 0 011 1v1" />
      </svg>
    </div>
    <h2 class="text-xl font-bold text-gray-800 mb-2">Log out?</h2>
    <p class="text-gray-500 text-sm mb-6">Are you sure you want to log out of the admin panel?</p>
    <div class="flex gap-3 justify-center">
      <button onclick="closeLogoutModal()"
              class="px-6 py-2.5 border border-stone-300 text-gray-600 rounded-xl hover:bg-stone-50 font-medium transition-all duration-200">
        Cancel
      </button>
      <a href="/admin/logout"
         class="px-6 py-2.5 bg-gradient-to-r from-stone-600 to-amber-800 text-white rounded-xl hover:opacity-90 font-medium transition-all duration-200">
        Yes, log out
      </a>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════ -->
<!--  SCRIPTS                                              -->
<!-- ══════════════════════════════════════════════════════ -->
<script>
const RANK_COLORS = ['#44200c','#78452a','#92400e','#d4853e','#e8a96b','#c9956e','#8c5c3a','#a07050','#c09070','#e0b090'];
const PIE_COLORS  = ['#44200c','#78452a','#b5652a','#d4853e','#e8a96b','#c9956e','#8c5c3a','#a07050','#c09070','#e0b090'];

let salesChart = null;
let currentChartFilter = 'weekly';
let currentLedgerFilter = 'monthly';
let currentLedgerYear = new Date().getFullYear();

// ── SALES CHART ────────────────────────────────────────────
function initSalesChart(labels, revenue, orders) {
  const ctx = document.getElementById('salesChart').getContext('2d');
  if (salesChart) salesChart.destroy();
  salesChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: 'Revenue (₹)',
          data: revenue,
          borderColor: '#92400e',
          backgroundColor: 'rgba(146,64,14,0.08)',
          fill: true, tension: 0.42,
          pointBackgroundColor: '#92400e', pointRadius: 4, pointHoverRadius: 7,
          borderWidth: 2.5, yAxisID: 'y'
        },
        {
          label: 'Orders',
          data: orders,
          borderColor: '#2563eb',
          backgroundColor: 'rgba(37,99,235,0.06)',
          fill: true, tension: 0.42,
          pointBackgroundColor: '#2563eb', pointRadius: 4, pointHoverRadius: 7,
          borderWidth: 2, borderDash: [5, 3], yAxisID: 'y1'
        }
      ]
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: {
          position: 'top',
          labels: { font: { family: 'Inter', size: 11 }, color: '#a8a29e', usePointStyle: true, pointStyleWidth: 10 }
        },
        tooltip: {
          backgroundColor: '#1c1917',
          titleFont: { family: 'Inter', size: 12, weight: '600' },
          bodyFont: { family: 'Inter', size: 11 }, padding: 12,
          callbacks: {
            label: ctx => ctx.datasetIndex === 0
              ? ` ₹${ctx.raw.toLocaleString('en-IN')}`
              : ` ${ctx.raw} orders`
          }
        }
      },
      scales: {
        x: {
          grid: { color: '#f0e3d0' },
          ticks: { font: { family: 'Inter', size: 10 }, color: '#a8a29e' }
        },
        y: {
          position: 'left', grid: { color: '#f0e3d0' },
          ticks: {
            font: { family: 'Inter', size: 10 }, color: '#a8a29e',
            callback: v => '₹' + (v >= 1000 ? (v / 1000).toFixed(0) + 'K' : v)
          }
        },
        y1: {
          position: 'right', grid: { drawOnChartArea: false },
          ticks: { font: { family: 'Inter', size: 10 }, color: '#2563eb' }
        }
      }
    }
  });
}

// ── CATEGORY LEGEND ────────────────────────────────────────
function renderCategoryLegend(categories) {
  const max = Math.max(...categories.map(c => c.unitsSold));
  document.getElementById('category-legend').innerHTML = categories.slice(0, 5).map((c, i) => `
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2 flex-1 min-w-0">
        <div class="w-2.5 h-2.5 rounded-sm flex-shrink-0" style="background:${PIE_COLORS[i]}"></div>
        <span class="text-xs text-stone-600 truncate">${c.name}</span>
      </div>
      <div class="flex-1 mx-3">
        <div class="prog-bar"><div class="prog-fill" style="width:${Math.round(c.unitsSold/max*100)}%;background:${PIE_COLORS[i]}"></div></div>
      </div>
      <span class="text-xs font-bold text-gray-800 w-8 text-right">${c.unitsSold}</span>
    </div>`).join('');
}

// ── RENDER TABLES ──────────────────────────────────────────
function renderBestProducts(products) {
  const maxRev = Math.max(...products.map(p => p.revenue));
  document.getElementById('best-products-tbody').innerHTML = products.map((p, i) => `
    <tr class="hover:bg-stone-50 transition-colors duration-150">
      <td class="px-4 py-3"><span class="rank-badge" style="background:${RANK_COLORS[i]}">${i + 1}</span></td>
      <td class="px-4 py-3 whitespace-nowrap text-xs font-semibold text-gray-900">${p.name}</td>
      <td class="px-4 py-3 whitespace-nowrap">
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-stone-200 text-stone-800">${p.category}</span>
      </td>
      <td class="px-4 py-3 whitespace-nowrap text-xs font-semibold text-gray-700">${p.unitsSold.toLocaleString('en-IN')}</td>
      <td class="px-4 py-3 whitespace-nowrap text-xs font-bold text-green-600">₹${p.revenue.toLocaleString('en-IN')}</td>
      <td class="px-4 py-3 whitespace-nowrap" style="min-width:100px;">
        <div class="prog-bar mb-1"><div class="prog-fill" style="width:${Math.round(p.revenue/maxRev*100)}%"></div></div>
        <span class="text-xs text-gray-400">${Math.round(p.revenue/maxRev*100)}%</span>
      </td>
    </tr>`).join('');
}

function renderBestCategories(cats) {
  const maxRev = Math.max(...cats.map(c => c.revenue));
  document.getElementById('best-categories-tbody').innerHTML = cats.map((c, i) => `
    <tr class="hover:bg-stone-50 transition-colors duration-150">
      <td class="px-4 py-3"><span class="rank-badge" style="background:${RANK_COLORS[i]}">${i + 1}</span></td>
      <td class="px-4 py-3 whitespace-nowrap text-xs font-semibold text-gray-900">${c.name}</td>
      <td class="px-4 py-3 whitespace-nowrap text-xs text-gray-500">${c.products || '—'}</td>
      <td class="px-4 py-3 whitespace-nowrap text-xs font-semibold text-gray-700">${c.unitsSold.toLocaleString('en-IN')}</td>
      <td class="px-4 py-3 whitespace-nowrap text-xs font-bold text-green-600">₹${c.revenue.toLocaleString('en-IN')}</td>
      <td class="px-4 py-3 whitespace-nowrap" style="min-width:100px;">
        <div class="prog-bar mb-1"><div class="prog-fill" style="width:${Math.round(c.revenue/maxRev*100)}%"></div></div>
        <span class="text-xs text-gray-400">${Math.round(c.revenue/maxRev*100)}%</span>
      </td>
    </tr>`).join('');
}

function renderLedger(entries) {
  const totals = entries.reduce((acc, e) => ({
    orders: acc.orders + e.orders, gross: acc.gross + e.gross,
    credits: acc.credits + e.credits, debits: acc.debits + e.debits, net: acc.net + e.net
  }), { orders: 0, gross: 0, credits: 0, debits: 0, net: 0 });

  document.getElementById('ledger-tbody').innerHTML = [
    ...entries.map(e => `
      <tr class="hover:bg-stone-50 transition-colors duration-150">
        <td class="px-4 py-3 text-xs font-semibold text-stone-700">${e.period}</td>
        <td class="px-4 py-3 text-xs text-gray-600">${e.orders}</td>
        <td class="px-4 py-3 text-xs text-gray-700">₹${e.gross.toLocaleString('en-IN')}</td>
        <td class="px-4 py-3 text-xs">₹${e.credits.toLocaleString('en-IN')}</td>
        <td class="px-4 py-3 text-xs">₹${e.debits.toLocaleString('en-IN')}</td>
        <td class="px-4 py-3 text-xs font-bold text-gray-800">₹${e.net.toLocaleString('en-IN')}</td>
        <td class="px-4 py-3 text-xs font-bold text-amber-700">₹${e.running.toLocaleString('en-IN')}</td>
      </tr>`),
    `<tr class="total-row">
      <td class="px-4 py-3 text-xs font-bold text-stone-800">TOTAL</td>
      <td class="px-4 py-3 text-xs">${totals.orders}</td>
      <td class="px-4 py-3 text-xs">₹${totals.gross.toLocaleString('en-IN')}</td>
      <td class="px-4 py-3 text-xs">₹${totals.credits.toLocaleString('en-IN')}</td>
      <td class="px-4 py-3 text-xs">₹${totals.debits.toLocaleString('en-IN')}</td>
      <td class="px-4 py-3 text-xs">₹${totals.net.toLocaleString('en-IN')}</td>
      <td class="px-4 py-3 text-xs">—</td>
    </tr>`
  ].join('');
}

// ── DATA FETCHING ──────────────────────────────────────────
function loadChart(period, btn) {
  currentChartFilter = period;
  document.querySelectorAll('#chart-filter-tabs .filter-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  fetch(`/admin/dashboard/chart-data?period=${period}`)
    .then(r => r.json())
    .then(d => initSalesChart(d.labels, d.revenue, d.orders))
    .catch(() => { const d = getDemoChartData(period); initSalesChart(d.labels, d.revenue, d.orders); });
}

function getDemoChartData(period) {
  if (period === 'weekly') return {
    labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
    revenue: [12400,9800,15600,11200,18900,22000,16500], orders: [14,12,18,13,22,28,19]
  };
  if (period === 'monthly') return {
    labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
    revenue: [45000,52000,48000,61000,58000,72000,69000,84000,76000,91000,88000,105000],
    orders: [42,50,46,58,55,68,65,79,72,86,83,99]
  };
  return {
    labels: ['2020','2021','2022','2023','2024','2025'],
    revenue: [280000,420000,560000,710000,890000,1050000], orders: [280,420,560,710,890,1050]
  };
}

function loadBestProducts() {
  fetch('/admin/dashboard/best-products')
    .then(r => r.json()).then(d => renderBestProducts(d.products))
    .catch(() => renderBestProducts([
      { name: 'Wireless Headphones', category: 'Electronics', unitsSold: 234, revenue: 455660 },
      { name: 'Smart Watch Pro',     category: 'Electronics', unitsSold: 189, revenue: 378000 },
      { name: 'Running Shoes X',     category: 'Footwear',    unitsSold: 156, revenue: 312000 },
      { name: 'Laptop Stand Pro',    category: 'Accessories', unitsSold: 142, revenue: 284000 },
      { name: 'Leather Wallet',      category: 'Bags',        unitsSold: 128, revenue: 128000 },
    ]));
}

function loadBestCategories() {
  fetch('/admin/dashboard/best-categories')
    .then(r => r.json())
    .then(d => { renderBestCategories(d.categories); renderCategoryLegend(d.categories); })
    .catch(() => {
      const cats = [
        { name: 'Electronics', products: 48, unitsSold: 521, revenue: 1042000 },
        { name: 'Footwear',    products: 32, unitsSold: 398, revenue: 796000  },
        { name: 'Bags',        products: 24, unitsSold: 212, revenue: 424000  },
        { name: 'Sports',      products: 18, unitsSold: 189, revenue: 283500  },
        { name: 'Accessories', products: 56, unitsSold: 175, revenue: 350000  },
      ];
      renderBestCategories(cats);
      renderCategoryLegend(cats);
    });
}

// ── LEDGER ─────────────────────────────────────────────────
function populateYearDropdown() {
  const sel = document.getElementById('ledger-year');
  const cur = new Date().getFullYear();
  for (let y = cur; y >= cur - 4; y--) {
    const opt = document.createElement('option');
    opt.value = y; opt.textContent = y; sel.appendChild(opt);
  }
  sel.value = cur;
}

function loadLedger(period, btn) {
  currentLedgerFilter = period;
  document.querySelectorAll('#ledger-filter-tabs .filter-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  loadCurrentLedger();
}

function loadCurrentLedger() {
  const year = document.getElementById('ledger-year').value;
  currentLedgerYear = year;
  fetch(`/admin/dashboard/ledger?period=${currentLedgerFilter}&year=${year}`)
    .then(r => r.json()).then(d => renderLedger(d.entries))
    .catch(() => renderLedger(getDemoLedger(currentLedgerFilter, year)));
}

function getDemoLedger(period, year) {
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  if (period === 'monthly') {
    let running = 0;
    return months.map(m => {
      const gross = Math.round(40000 + Math.random() * 60000);
      const debits = Math.round(gross * 0.11); const net = gross - debits; running += net;
      return { period: `${m} ${year}`, orders: Math.round(30 + Math.random() * 70), gross, credits: net, debits, net, running };
    });
  }
  if (period === 'quarterly') {
    let running = 0;
    return ['Q1','Q2','Q3','Q4'].map(q => {
      const gross = Math.round(120000 + Math.random() * 180000);
      const debits = Math.round(gross * 0.11); const net = gross - debits; running += net;
      return { period: `${q} ${year}`, orders: Math.round(90 + Math.random() * 210), gross, credits: net, debits, net, running };
    });
  }
  let running = 0;
  return Array.from({ length: 5 }, (_, i) => {
    const y = parseInt(year) - 4 + i;
    const gross = Math.round(500000 + Math.random() * 700000);
    const debits = Math.round(gross * 0.11); const net = gross - debits; running += net;
    return { period: String(y), orders: Math.round(400 + Math.random() * 800), gross, credits: net, debits, net, running };
  });
}

// ── TAB SWITCHING ──────────────────────────────────────────
function switchTab(name) {
  ['products', 'categories', 'ledger'].forEach(t => {
    document.getElementById('tab-' + t).classList.toggle('active', t === name);
    document.getElementById('tab-btn-' + t).classList.toggle('active', t === name);
  });
}

// ── EXPORT ─────────────────────────────────────────────────
function exportLedgerExcel() {
  const rows = document.querySelectorAll('#ledger-tbody tr');
  if (!rows.length) return;
  const year = document.getElementById('ledger-year').value;
  const headers = ['Period','Orders','Gross Revenue','Credits (+)','Debits (−)','Net Balance','Running Total'];
  const data = Array.from(rows).map(r => Array.from(r.querySelectorAll('td')).map(td => td.textContent.trim()));
  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.aoa_to_sheet([[`AdminHub Ledger — ${year} (${currentLedgerFilter})`], [], headers, ...data]);
  ws['!cols'] = headers.map(() => ({ wch: 18 }));
  XLSX.utils.book_append_sheet(wb, ws, 'Ledger');
  XLSX.writeFile(wb, `ledger-${currentLedgerFilter}-${year}.xlsx`);
}

function printLedger() {
  const year = document.getElementById('ledger-year').value;
  const tableHTML = document.getElementById('ledger-table').outerHTML;
  const win = window.open('', '_blank');
  win.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Ledger ${year}</title><style>body{font-family:Arial,sans-serif;margin:24px;font-size:12px}h2{color:#44200c}p{color:#a08070;font-size:11px;margin-bottom:20px}table{width:100%;border-collapse:collapse}th{background:#44200c;color:white;padding:8px 12px;text-align:left;font-size:10px;text-transform:uppercase}td{padding:8px 12px;border-bottom:1px solid #f0e3d0;font-size:11px}tr:nth-child(even)td{background:#fdf6ed}tr:last-child td{background:#f5e9d6;font-weight:700}td:nth-child(4){color:#16a34a}td:nth-child(5){color:#dc2626}</style></head><body><h2>Ledger Book — ${year}</h2><p>Period: ${currentLedgerFilter} | Generated: ${new Date().toLocaleString('en-IN')}</p>${tableHTML}</body></html>`);
  win.document.close();
  setTimeout(() => win.print(), 400);
}

// ── LOGOUT MODAL ───────────────────────────────────────────
function showLogoutModal(e) {
  e.preventDefault();
  document.getElementById('logout-modal').style.display = 'flex';
}
function closeLogoutModal() {
  document.getElementById('logout-modal').style.display = 'none';
}
document.getElementById('logout-modal').addEventListener('click', function(e) {
  if (e.target === this) closeLogoutModal();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLogoutModal(); });

// ── INIT ────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  const demo = getDemoChartData('weekly');
  initSalesChart(demo.labels, demo.revenue, demo.orders);
  loadBestProducts();
  loadBestCategories();
  populateYearDropdown();
  loadCurrentLedger();
});
</script>

</body>
</html>
